<%- include('../partials/head') %>
<body class="bg-light d-flex align-items-center justify-content-center" style="min-height: 100vh;">
  <div class="text-center p-5">
    <div class="mb-4">
      <i class="bi bi-exclamation-triangle text-danger" style="font-size: 5rem;"></i>
    </div>
    <h1 class="fw-bold text-dark mb-2"><%= typeof statusCode !== 'undefined' ? statusCode : '500' %></h1>
    <h4 class="text-secondary mb-4"><%= typeof message !== 'undefined' ? message : 'เกิดข้อผิดพลาดบางอย่าง' %></h4>
    
    <% if (typeof error !== 'undefined' && error.stack) { %>
      <div class="text-start mx-auto p-3 bg-dark text-light rounded-3 mb-4" style="max-width: 600px; font-size: 0.8rem; overflow-x: auto;">
        <pre class="mb-0"><%= error.stack %></pre>
      </div>
    <% } %>

    <a href="/dashboard" class="btn btn-hospital px-4 py-2 rounded-3">
      กลับสู่แดชบอร์ด
    </a>
  </div>
  <%- include('../partials/scripts') %>
</body>
</html>
