<div class="row mb-4">
  <div class="col-12 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <h3 class="fw-bold text-dark mb-0">จัดการข้อมูลหมวดหมู่ & กลุ่มกิจกรรม</h3>
      <p class="text-secondary small mb-0">กำหนดค่าหมวดหมู่ระดับหลักและกลุ่มย่อยสำหรับการจัดหมวดหมู่ภาระงาน</p>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-hospital px-3 shadow-sm text-sm" data-bs-toggle="modal" data-bs-target="#createCategoryModal">
        <i class="bi bi-plus-lg me-1"></i>เพิ่มหมวดหมู่
      </button>
      <button class="btn btn-teal-light px-3 border border-teal text-teal text-sm" data-bs-toggle="modal" data-bs-target="#createGroupModal">
        <i class="bi bi-folder-plus me-1"></i>เพิ่มกลุ่มกิจกรรม
      </button>
    </div>
  </div>
</div>

<div class="row g-4">
  <!-- Categories Card -->
  <div class="col-md-6">
    <div class="card card-hospital border-0 p-3 h-100 bg-white shadow-sm">
      <h5 class="fw-bold text-dark mb-3">หมวดหมู่หลัก (Master Categories)</h5>
      
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 text-sm">
          <thead class="table-light">
            <tr>
              <th class="ps-3">ชื่อหมวดหมู่</th>
              <th>คำอธิบาย</th>
              <th>สถานะ</th>
              <th class="pe-3 text-end">จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% if (categories && categories.length > 0) { %>
              <% categories.forEach(function(cat) { %>
                <tr>
                  <td class="ps-3 fw-semibold text-dark"><%= cat.name %></td>
                  <td class="text-secondary text-xs"><%= cat.description || '-' %></td>
                  <td>
                    <% if (cat.is_active) { %>
                      <span class="badge bg-success-subtle text-success border border-success-subtle rounded-2">ใช้งาน</span>
                    <% } else { %>
                      <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-2">ปิดใช้งาน</span>
                    <% } %>
                  </td>
                  <td class="pe-3 text-end">
                    <button class="btn btn-sm btn-light border rounded-2 p-1" onclick="openEditCategoryModal(<%= cat.id %>, '<%= cat.name %>', '<%= cat.description || '' %>')">
                      <i class="bi bi-pencil-fill text-secondary"></i>
                    </button>
                    <button class="btn btn-sm btn-light border rounded-2 p-1" onclick="deleteCategory(<%= cat.id %>)">
                      <i class="bi bi-trash-fill text-danger"></i>
                    </button>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center py-4 text-muted">ยังไม่มีข้อมูลหมวดหมู่</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- Sub-groups Card -->
  <div class="col-md-6">
    <div class="card card-hospital border-0 p-3 h-100 bg-white shadow-sm">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="fw-bold text-dark mb-0">กลุ่มกิจกรรมย่อย (Sub-Groups)</h5>
      </div>
      
      <!-- Category Filter Chips -->
      <div class="d-flex flex-wrap gap-2 mb-3">
        <button type="button" class="chip-btn filter-group-btn" data-category="all" onclick="filterGroupsByCategory('all', this)">ทั้งหมด</button>
        <% if (categories && categories.length > 0) { %>
          <% categories.forEach(function(cat) { %>
            <button type="button" class="chip-btn filter-group-btn <%= cat.name === 'IT' ? 'active' : '' %>" data-category="<%= cat.id %>" onclick="filterGroupsByCategory('<%= cat.id %>', this)">
              <%= cat.name %>
            </button>
          <% }); %>
        <% } %>
      </div>
      
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 text-sm">
          <thead class="table-light">
            <tr>
              <th class="ps-3">ชื่อกลุ่มกิจกรรม</th>
              <th>หมวดหมู่</th>
              <th>คำอธิบาย</th>
              <th>สถานะ</th>
              <th class="pe-3 text-end">จัดการ</th>
            </tr>
          </thead>
          <tbody>
            <% if (groups && groups.length > 0) { %>
              <% groups.forEach(function(grp) { %>
                <tr class="group-row" data-category-id="<%= grp.category_id || 'null' %>">
                  <td class="ps-3 fw-semibold text-dark"><%= grp.name %></td>
                  <td><span class="badge bg-light text-secondary border"><%= grp.category_name || '-' %></span></td>
                  <td class="text-secondary text-xs"><%= grp.description || '-' %></td>
                  <td>
                    <% if (grp.is_active) { %>
                      <span class="badge bg-success-subtle text-success border border-success-subtle rounded-2">ใช้งาน</span>
                    <% } else { %>
                      <span class="badge bg-danger-subtle text-danger border border-danger-subtle rounded-2">ปิดใช้งาน</span>
                    <% } %>
                  </td>
                  <td class="pe-3 text-end">
                    <button class="btn btn-sm btn-light border rounded-2 p-1" onclick="openEditGroupModal(<%= grp.id %>, '<%= grp.name %>', '<%= grp.description || '' %>', <%= grp.category_id || 'null' %>)">
                      <i class="bi bi-pencil-fill text-secondary"></i>
                    </button>
                    <button class="btn btn-sm btn-light border rounded-2 p-1" onclick="deleteGroup(<%= grp.id %>)">
                      <i class="bi bi-trash-fill text-danger"></i>
                    </button>
                  </td>
                </tr>
              <% }); %>
            <% } else { %>
              <tr>
                <td colspan="4" class="text-center py-4 text-muted">ยังไม่มีข้อมูลกลุ่มกิจกรรม</td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<!-- Modal Add Category -->
<div class="modal fade" id="createCategoryModal" tabindex="-1" aria-labelledby="createCategoryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 440px;">
    <div class="modal-content border-0 rounded-card shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold text-dark" id="createCategoryModalLabel">เพิ่มหมวดหมู่หลัก</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/category/create" method="POST">
        <div class="modal-body py-3">
          <div class="mb-3">
            <label for="newCategoryName" class="form-label text-secondary small fw-semibold">ชื่อหมวดหมู่</label>
            <input type="text" class="form-control rounded-3" id="newCategoryName" name="name" required placeholder="เช่น IT, บริหารงานทั่วไป">
          </div>
          <div class="mb-3">
            <label for="newCategoryDesc" class="form-label text-secondary small fw-semibold">คำอธิบายรายละเอียด</label>
            <textarea class="form-control rounded-3" id="newCategoryDesc" name="description" rows="3" placeholder="อธิบายวัตถุประสงค์สั้นๆ..."></textarea>
          </div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-hospital rounded-3 px-4">บันทึกข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Edit Category -->
<div class="modal fade" id="editCategoryModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 440px;">
    <div class="modal-content border-0 rounded-card shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold text-dark">แก้ไขหมวดหมู่หลัก</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editCategoryForm" onsubmit="submitEditCategory(event)">
        <div class="modal-body py-3">
          <input type="hidden" id="editCategoryId">
          <div class="mb-3">
            <label for="editCategoryName" class="form-label text-secondary small fw-semibold">ชื่อหมวดหมู่</label>
            <input type="text" class="form-control rounded-3" id="editCategoryName" required>
          </div>
          <div class="mb-3">
            <label for="editCategoryDesc" class="form-label text-secondary small fw-semibold">คำอธิบายรายละเอียด</label>
            <textarea class="form-control rounded-3" id="editCategoryDesc" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-hospital rounded-3 px-4">บันทึกการแก้ไข</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Add Group -->
<div class="modal fade" id="createGroupModal" tabindex="-1" aria-labelledby="createGroupModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 440px;">
    <div class="modal-content border-0 rounded-card shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold text-dark" id="createGroupModalLabel">เพิ่มกลุ่มกิจกรรมย่อย</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form action="/category/group/create" method="POST">
        <div class="modal-body py-3">
          <div class="mb-3">
            <label for="newGroupName" class="form-label text-secondary small fw-semibold">ชื่อกลุ่มกิจกรรมย่อย</label>
            <input type="text" class="form-control rounded-3" id="newGroupName" name="name" required placeholder="เช่น Hardware, Software">
          </div>
          <div class="mb-3">
            <label for="newGroupCategory" class="form-label text-secondary small fw-semibold">สังกัดหมวดหมู่หลัก</label>
            <select class="form-select rounded-3" id="newGroupCategory" name="category_id" required>
              <option value="">เลือกหมวดหมู่หลัก...</option>
              <% if (categories && categories.length > 0) { %>
                <% categories.forEach(function(cat) { %>
                  <option value="<%= cat.id %>"><%= cat.name %></option>
                <% }); %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label for="newGroupDesc" class="form-label text-secondary small fw-semibold">คำอธิบายรายละเอียด</label>
            <textarea class="form-control rounded-3" id="newGroupDesc" name="description" rows="3" placeholder="อธิบายวัตถุประสงค์สั้นๆ..."></textarea>
          </div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-hospital rounded-3 px-4">บันทึกข้อมูล</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Modal Edit Group -->
<div class="modal fade" id="editGroupModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 440px;">
    <div class="modal-content border-0 rounded-card shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold text-dark">แก้ไขกลุ่มกิจกรรมย่อย</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="editGroupForm" onsubmit="submitEditGroup(event)">
        <div class="modal-body py-3">
          <input type="hidden" id="editGroupId">
          <div class="mb-3">
            <label for="editGroupName" class="form-label text-secondary small fw-semibold">ชื่อกลุ่มกิจกรรม</label>
            <input type="text" class="form-control rounded-3" id="editGroupName" required>
          </div>
          <div class="mb-3">
            <label for="editGroupCategory" class="form-label text-secondary small fw-semibold">สังกัดหมวดหมู่หลัก</label>
            <select class="form-select rounded-3" id="editGroupCategory" required>
              <option value="">เลือกหมวดหมู่หลัก...</option>
              <% if (categories && categories.length > 0) { %>
                <% categories.forEach(function(cat) { %>
                  <option value="<%= cat.id %>"><%= cat.name %></option>
                <% }); %>
              <% } %>
            </select>
          </div>
          <div class="mb-3">
            <label for="editGroupDesc" class="form-label text-secondary small fw-semibold">คำอธิบายรายละเอียด</label>
            <textarea class="form-control rounded-3" id="editGroupDesc" rows="3"></textarea>
          </div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-hospital rounded-3 px-4">บันทึกการแก้ไข</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  let editCategoryModal;
  let editGroupModal;

  document.addEventListener('DOMContentLoaded', () => {
    editCategoryModal = new bootstrap.Modal(document.getElementById('editCategoryModal'));
    editGroupModal = new bootstrap.Modal(document.getElementById('editGroupModal'));
  });

  // --- Category Actions ---
  function openEditCategoryModal(id, name, description) {
    document.getElementById('editCategoryId').value = id;
    document.getElementById('editCategoryName').value = name;
    document.getElementById('editCategoryDesc').value = description;
    editCategoryModal.show();
  }

  async function submitEditCategory(event) {
    event.preventDefault();
    const id = document.getElementById('editCategoryId').value;
    const name = document.getElementById('editCategoryName').value;
    const description = document.getElementById('editCategoryDesc').value;

    try {
      const response = await fetch(`/category/update/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, description })
      });
      const data = await response.json();
      if (data.success) {
        editCategoryModal.hide();
        Swal.fire({
          title: 'สำเร็จ!',
          text: data.message,
          icon: 'success',
          timer: 1500,
          showConfirmButton: false
        }).then(() => window.location.reload());
      } else {
        Swal.fire('ผิดพลาด!', data.message || 'บันทึกข้อมูลไม่สำเร็จ', 'error');
      }
    } catch (err) {
      Swal.fire('ผิดพลาด!', 'เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์', 'error');
    }
  }

  function deleteCategory(id) {
    Swal.fire({
      title: 'ลบหมวดหมู่หลัก?',
      text: 'คุณต้องการลบหมวดหมู่หลักนี้ออกจากระบบใช่หรือไม่?',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#0D9488',
      cancelButtonColor: '#EF4444',
      confirmButtonText: 'ลบเลย',
      cancelButtonText: 'ยกเลิก'
    }).then(async (result) => {
      if (result.isConfirmed) {
        try {
          const response = await fetch(`/category/delete/${id}`, { method: 'DELETE' });
          const data = await response.json();
          if (data.success) {
            Swal.fire({
              title: 'สำเร็จ!',
              text: data.message,
              icon: 'success',
              timer: 1500,
              showConfirmButton: false
            }).then(() => window.location.reload());
          } else {
            Swal.fire('ผิดพลาด!', data.message || 'ลบข้อมูลไม่สำเร็จ', 'error');
          }
        } catch (err) {
          Swal.fire('ผิดพลาด!', 'เกิดข้อผิดพลาดในการเชื่อมต่อ', 'error');
        }
      }
    });
  }

  // --- Group Actions ---
  function openEditGroupModal(id, name, description, categoryId) {
    document.getElementById('editGroupId').value = id;
    document.getElementById('editGroupName').value = name;
    document.getElementById('editGroupDesc').value = description;
    document.getElementById('editGroupCategory').value = categoryId || '';
    editGroupModal.show();
  }

  async function submitEditGroup(event) {
    event.preventDefault();
    const id = document.getElementById('editGroupId').value;
    const name = document.getElementById('editGroupName').value;
    const description = document.getElementById('editGroupDesc').value;
    const category_id = document.getElementById('editGroupCategory').value;

    try {
      const response = await fetch(`/category/group/update/${id}`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, description, category_id })
      });
      const data = await response.json();
      if (data.success) {
        editGroupModal.hide();
        Swal.fire({
          title: 'สำเร็จ!',
          text: data.message,
          icon: 'success',
          timer: 1500,
          showConfirmButton: false
        }).then(() => window.location.reload());
      } else {
        Swal.fire('ผิดพลาด!', data.message || 'บันทึกข้อมูลไม่สำเร็จ', 'error');
      }
    } catch (err) {
      Swal.fire('ผิดพลาด!', 'เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์', 'error');
    }
  }

  function deleteGroup(id) {
    Swal.fire({
      title: 'ลบกลุ่มกิจกรรม?',
      text: 'คุณต้องการลบกลุ่มกิจกรรมย่อยนี้ออกจากระบบใช่หรือไม่?',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#0D9488',
      cancelButtonColor: '#EF4444',
      confirmButtonText: 'ลบเลย',
      cancelButtonText: 'ยกเลิก'
    }).then(async (result) => {
      if (result.isConfirmed) {
        try {
          const response = await fetch(`/category/group/delete/${id}`, { method: 'DELETE' });
          const data = await response.json();
          if (data.success) {
            Swal.fire({
              title: 'สำเร็จ!',
              text: data.message,
              icon: 'success',
              timer: 1500,
              showConfirmButton: false
            }).then(() => window.location.reload());
          } else {
            Swal.fire('ผิดพลาด!', data.message || 'ลบข้อมูลไม่สำเร็จ', 'error');
          }
        } catch (err) {
          Swal.fire('ผิดพลาด!', 'เกิดข้อผิดพลาดในการเชื่อมต่อ', 'error');
        }
      }
    });
  }

  // --- Filter Groups ---
  function filterGroupsByCategory(categoryId, element) {
    // Update active state
    if (element) {
      document.querySelectorAll('.filter-group-btn').forEach(btn => btn.classList.remove('active'));
      element.classList.add('active');
    }

    const rows = document.querySelectorAll('.group-row');
    let visibleCount = 0;

    rows.forEach(row => {
      const rowCategory = row.getAttribute('data-category-id');
      if (categoryId === 'all' || rowCategory === categoryId.toString()) {
        row.style.display = '';
        visibleCount++;
      } else {
        row.style.display = 'none';
      }
    });

    // Handle empty state
    let emptyRow = document.getElementById('emptyGroupRow');
    if (visibleCount === 0) {
      if (!emptyRow) {
        const tbody = document.querySelector('.group-row').parentNode;
        emptyRow = document.createElement('tr');
        emptyRow.id = 'emptyGroupRow';
        emptyRow.innerHTML = '<td colspan="5" class="text-center py-4 text-muted">ไม่พบข้อมูลกลุ่มกิจกรรมในหมวดหมู่นี้</td>';
        tbody.appendChild(emptyRow);
      } else {
        emptyRow.style.display = '';
      }
    } else if (emptyRow) {
      emptyRow.style.display = 'none';
    }
  }

  // Initialize group filter on load to "IT" or whatever is active
  document.addEventListener('DOMContentLoaded', () => {
    const activeBtn = document.querySelector('.filter-group-btn.active');
    if (activeBtn) {
      const categoryId = activeBtn.getAttribute('data-category');
      filterGroupsByCategory(categoryId, activeBtn);
    } else {
      // Fallback to all if no IT category exists
      const allBtn = document.querySelector('.filter-group-btn[data-category="all"]');
      if (allBtn) {
        allBtn.classList.add('active');
        filterGroupsByCategory('all', allBtn);
      }
    }
  });
</script>
