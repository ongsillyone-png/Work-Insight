<div class="row mb-4">
  <div class="col-12 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div>
      <h2 class="fw-bold text-dark mb-0">Activity Categories & Groups</h2>
      <p class="text-secondary mb-0">Manage global categories and sub-groups of daily medical digital operations.</p>
    </div>
    <div>
      <button class="btn btn-hospital px-4 py-2 rounded-3 fw-medium shadow-sm" data-bs-toggle="modal" data-bs-target="#createCategoryModal">
        <i class="bi bi-plus-lg me-2"></i>Add Category
      </button>
    </div>
  </div>
</div>

<div class="row g-4">
  <!-- Categories Table Card -->
  <div class="col-md-6">
    <div class="card rounded-card border-0 shadow-sm h-100">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="fw-bold text-dark mb-0">Categories (Master Category)</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Category Name</th>
                <th>Status</th>
                <th class="pe-4 text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <!-- Predefined categories requested by user -->
              <% const categoriesList = ['IT', 'แผนงาน', 'ประชาสัมพันธ์', 'ประชุม', 'บริหาร', 'เอกสาร']; %>
              <% categoriesList.forEach(function(cat, index) { %>
                <tr>
                  <td class="ps-4 fw-semibold text-dark"><%= cat %></td>
                  <td><span class="badge bg-success-subtle text-success border border-success-subtle rounded-2">Active</span></td>
                  <td class="pe-4 text-end">
                    <button class="btn btn-sm btn-outline-secondary rounded-2 me-1"><i class="bi bi-pencil"></i></button>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Groups Table Card -->
  <div class="col-md-6">
    <div class="card rounded-card border-0 shadow-sm h-100">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="fw-bold text-dark mb-0">Sub-Groups (Activity Groups)</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th class="ps-4">Group Name</th>
                <th>Status</th>
                <th class="pe-4 text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <!-- Predefined groups requested by user -->
              <% const groupsList = ['Hardware', 'Software', 'Database', 'Server', 'Network', 'Graphic', 'HAIT', 'KPI']; %>
              <% groupsList.forEach(function(grp, index) { %>
                <tr>
                  <td class="ps-4 fw-semibold text-dark"><%= grp %></td>
                  <td><span class="badge bg-success-subtle text-success border border-success-subtle rounded-2">Active</span></td>
                  <td class="pe-4 text-end">
                    <button class="btn btn-sm btn-outline-secondary rounded-2 me-1"><i class="bi bi-pencil"></i></button>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Dummy Add Category Modal -->
<div class="modal fade" id="createCategoryModal" tabindex="-1" aria-labelledby="createCategoryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content rounded-card border-0">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold text-dark" id="createCategoryModalLabel">Add Category</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body py-4">
        <div class="mb-3">
          <label for="newCategoryName" class="form-label text-secondary small fw-semibold">Category Name</label>
          <input type="text" class="form-control rounded-3" id="newCategoryName" placeholder="e.g. IT, Admin">
        </div>
        <div class="mb-3">
          <label for="newCategoryDesc" class="form-label text-secondary small fw-semibold">Description</label>
          <textarea class="form-control rounded-3" id="newCategoryDesc" rows="2" placeholder="Brief description..."></textarea>
        </div>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-light rounded-3" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-hospital rounded-3" data-bs-dismiss="modal">Save Category</button>
      </div>
    </div>
  </div>
</div>
