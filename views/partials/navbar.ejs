<!-- User Preferences Modal -->
<div class="modal fade" id="userPreferencesModal" tabindex="-1" aria-labelledby="userPreferencesModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 440px;">
    <div class="modal-content border-0 rounded-card shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold text-dark" id="userPreferencesModalLabel">ตั้งค่าการแสดงผลหมวดหมู่</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="userPreferencesForm" onsubmit="submitUserPreferences(event)">
        <div class="modal-body py-3">
          <p class="text-secondary small mb-3">เลือกเฉพาะหมวดหมู่ที่คุณต้องการให้แสดงในหน้าบันทึกกิจกรรม เพื่อให้หน้าจอของคุณสะอาดและใช้งานง่ายขึ้น (หากไม่เลือกเลย ระบบจะแสดงทุกหมวดหมู่)</p>
          
          <div class="d-flex flex-column gap-2" id="preferencesCheckboxes">
            <% 
              const prefs = typeof user !== 'undefined' && user.preferred_categories 
                              ? user.preferred_categories.split(',').map(s => s.trim()) 
                              : [];
              if (typeof allCategories !== 'undefined' && allCategories.length > 0) {
                allCategories.forEach(function(cat) { 
                  const isChecked = prefs.length === 0 || prefs.includes(cat.id.toString()) ? 'checked' : '';
            %>
              <div class="form-check custom-checkbox p-2 border rounded-3 hover-bg-light">
                <input class="form-check-input ms-1 me-2 pref-cat-check" type="checkbox" value="<%= cat.id %>" id="prefCat<%= cat.id %>" <%= isChecked %>>
                <label class="form-check-label w-100 fw-semibold text-dark" style="cursor:pointer;" for="prefCat<%= cat.id %>">
                  <%= cat.name %>
                </label>
              </div>
            <% 
                });
              } 
            %>
          </div>
        </div>
        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-hospital rounded-3 px-4">บันทึกการตั้งค่า</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  async function submitUserPreferences(event) {
    event.preventDefault();
    const checkboxes = document.querySelectorAll('.pref-cat-check:checked');
    const selectedIds = Array.from(checkboxes).map(cb => cb.value);
    
    // If all are selected, we can also just clear the preference or save them all.
    // Let's save the selected IDs as a comma-separated string.
    // If none are selected, it becomes an empty string, which means "show all" by default, 
    // but the user might have literally wanted to hide all. However, "show all if empty" is a better UX.
    const preferred_categories = selectedIds.join(',');

    try {
      const response = await fetch('/users/preferences', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ preferred_categories })
      });
      const data = await response.json();
      if (data.success) {
        if (typeof bootstrap !== 'undefined') {
           bootstrap.Modal.getInstance(document.getElementById('userPreferencesModal')).hide();
        }
        Swal.fire({
          title: 'สำเร็จ!',
          text: data.message,
          icon: 'success',
          timer: 1500,
          showConfirmButton: false
        }).then(() => window.location.reload());
      } else {
        Swal.fire('ผิดพลาด!', data.message || 'บันทึกข้อมูลไม่สำเร็จ', 'error');
      }
    } catch (err) {
      Swal.fire('ผิดพลาด!', 'เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์', 'error');
    }
  }
</script>
