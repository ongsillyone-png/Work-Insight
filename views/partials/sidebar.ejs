<aside class="app-sidebar bg-body-dark shadow" data-bs-theme="dark">
  <!-- Brand Logo -->
  <a href="/home" class="brand-link text-center d-block text-decoration-none py-3">
    <span class="brand-text fs-4 fw-bold">Work Insight</span>
  </a>

  <!-- Sidebar -->
  <div class="sidebar px-2">
    <!-- Sidebar Menu -->
    <nav class="mt-4">
      <ul class="nav nav-pills nav-sidebar flex-column" role="menu">
        
        <li class="nav-item">
          <a href="/home" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'home' ? 'active' : '' %>">
            <i class="nav-icon bi bi-house-door"></i>
            <p>หน้าแรก</p>
          </a>
        </li>
        
        <li class="nav-item">
          <a href="/activity/create" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'record_activity' ? 'active' : '' %>">
            <i class="nav-icon bi bi-plus-circle-dotted"></i>
            <p>บันทึกกิจกรรม</p>
          </a>
        </li>

        <li class="nav-item">
          <a href="/activity" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'activity' ? 'active' : '' %>">
            <i class="nav-icon bi bi-calendar3"></i>
            <p>Timeline</p>
          </a>
        </li>

        <li class="nav-item">
          <a href="/dashboard" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'dashboard' ? 'active' : '' %>">
            <i class="nav-icon bi bi-bar-chart-line"></i>
            <p>Dashboard</p>
          </a>
        </li>

        <!-- ตั้งค่ากิจกรรม Collapse (All Users) -->
        <% const isActivitySettingsActive = ['category', 'activity_master', 'locations'].includes(typeof activeMenu !== 'undefined' ? activeMenu : ''); %>
        <li class="nav-item">
          <a class="nav-link d-flex align-items-center justify-content-between" data-bs-toggle="collapse" href="#activitySettingsCollapse" role="button" aria-expanded="<%= isActivitySettingsActive ? 'true' : 'false' %>" aria-controls="activitySettingsCollapse">
            <div class="d-flex align-items-center gap-2">
              <i class="nav-icon bi bi-list-task"></i>
              <span>ตั้งค่ากิจกรรม</span>
            </div>
            <i class="bi bi-chevron-down nav-arrow-icon <%= isActivitySettingsActive ? 'rotate-180' : '' %>" style="font-size: 0.8rem;"></i>
          </a>
          <div class="collapse <%= isActivitySettingsActive ? 'show' : '' %>" id="activitySettingsCollapse">
            <ul class="nav flex-column ps-3 mt-1" style="list-style: none; padding-left: 0;">
              <li class="nav-item">
                <a href="/category" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'category' ? 'active' : '' %>">
                  <i class="nav-icon bi bi-tags"></i>
                  <p class="mb-0 d-inline-block">หมวดกิจกรรม</p>
                </a>
              </li>
              <li class="nav-item">
                <a href="/activity-master" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'activity_master' ? 'active' : '' %>">
                  <i class="nav-icon bi bi-lightning-charge"></i>
                  <p class="mb-0 d-inline-block">กิจกรรม</p>
                </a>
              </li>
              <li class="nav-item">
                <a href="/locations" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'locations' ? 'active' : '' %>">
                  <i class="nav-icon bi bi-geo-alt"></i>
                  <p class="mb-0 d-inline-block">สถานที่</p>
                </a>
              </li>
            </ul>
          </div>
        </li>

        <!-- จัดการระบบ Collapse (เฉพาะ Admin เท่านั้น) -->
        <% if (typeof user !== 'undefined' && user.role === 'Admin') { %>
          <% const isSystemActive = ['user', 'setting'].includes(typeof activeMenu !== 'undefined' ? activeMenu : ''); %>
          <li class="nav-item">
            <a class="nav-link d-flex align-items-center justify-content-between" data-bs-toggle="collapse" href="#systemManagementCollapse" role="button" aria-expanded="<%= isSystemActive ? 'true' : 'false' %>" aria-controls="systemManagementCollapse">
              <div class="d-flex align-items-center gap-2">
                <i class="nav-icon bi bi-gear"></i>
                <span>จัดการระบบ</span>
              </div>
              <i class="bi bi-chevron-down nav-arrow-icon <%= isSystemActive ? 'rotate-180' : '' %>" style="font-size: 0.8rem;"></i>
            </a>
            <div class="collapse <%= isSystemActive ? 'show' : '' %>" id="systemManagementCollapse">
              <ul class="nav flex-column ps-3 mt-1" style="list-style: none; padding-left: 0;">
                <li class="nav-item">
                  <a href="/users" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'user' ? 'active' : '' %>">
                    <i class="nav-icon bi bi-people"></i>
                    <p class="mb-0 d-inline-block">ผู้ใช้งาน</p>
                  </a>
                </li>
                <li class="nav-item">
                  <a href="/settings" class="nav-link <%= typeof activeMenu !== 'undefined' && activeMenu === 'setting' ? 'active' : '' %>">
                    <i class="nav-icon bi bi-sliders"></i>
                    <p class="mb-0 d-inline-block">ตั้งค่า</p>
                  </a>
                </li>
              </ul>
            </div>
          </li>
        <% } %>

      </ul>
    </nav>
    <!-- /.sidebar-menu -->
  </div>
  <!-- /.sidebar -->
</aside>
