<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'Work Insight' %></title>

  <!-- Google Font: Source Sans Pro & Inter -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Sarabun:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <!-- Bootstrap 5.3 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" crossorigin="anonymous">
  
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">

  <!-- AdminLTE 4 CSS -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@4.0.0-beta2/dist/css/adminlte.min.css" crossorigin="anonymous">

  <!-- Tom Select CSS -->
  <link href="https://cdn.jsdelivr.net/npm/tom-select@2.3.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet">

  <!-- SweetAlert2 CSS -->
  <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.8/dist/sweetalert2.min.css" rel="stylesheet">

  <style>
    :root {
      --bs-font-sans-serif: 'Sarabun', 'Inter', system-ui, -apple-system, sans-serif;
      --hospital-teal: #0d8a72;
      --hospital-teal-dark: #0a6b58;
      --hospital-teal-light: #e6f3f0;
    }
    body {
      font-family: var(--bs-font-sans-serif);
      background-color: #f4f6f9;
      font-size: 0.95rem;
    }
    .brand-link {
      background-color: var(--hospital-teal);
      color: white !important;
      font-weight: 600;
      border-bottom: 1px solid var(--hospital-teal-dark) !important;
    }
    .brand-link:hover {
      background-color: var(--hospital-teal-dark);
    }
    .sidebar-dark-primary {
      background-color: #212529 !important;
    }
    .sidebar-dark-primary .nav-sidebar > .nav-item > .nav-link.active {
      background-color: var(--hospital-teal) !important;
      color: #fff !important;
    }
    .main-header {
      border-bottom: 1px solid #dee2e6;
    }
    .navbar-light {
      background-color: #ffffff !important;
    }
    .card-hospital {
      border-top: 4px solid var(--hospital-teal) !important;
      border-radius: 12px !important;
      box-shadow: 0 4px 6px rgba(0,0,0,0.05);
    }
    .btn-hospital {
      background-color: var(--hospital-teal);
      color: white;
      border: none;
      transition: all 0.2s;
    }
    .btn-hospital:hover {
      background-color: var(--hospital-teal-dark);
      color: white;
    }
    .rounded-card {
      border-radius: 12px !important;
    }
    .bg-hospital-light {
      background-color: var(--hospital-teal-light) !important;
      color: var(--hospital-teal-dark) !important;
    }
  </style>
</head>
