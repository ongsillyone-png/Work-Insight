<!-- Analytical Dashboard View for Managers/Department Heads -->
<div class="row mb-4">
  <div class="col-12">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div>
        <h3 class="fw-bold text-dark mb-1">ภาพรวมการวิเคราะห์ (Dashboard)</h3>
        <p class="text-secondary small mb-0">รายงานภาระงานดิจิทัลทางการแพทย์และตัวชี้วัดระดับแผนก</p>
      </div>
      <div>
        <span class="badge bg-hospital-light p-2.5 rounded-3 fw-semibold">
          <i class="bi bi-shield-check me-2"></i>สำหรับหัวหน้ากลุ่มงาน (Head View)
        </span>
      </div>
    </div>
  </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
  
  <div class="col-md-4">
    <div class="card card-hospital p-4 border-0 bg-white h-100">
      <div class="d-flex align-items-center justify-content-between">
        <div>
          <span class="text-secondary text-xs fw-semibold uppercase tracking-wider">ภาระงานที่บันทึกรวม</span>
          <h2 class="fw-bold text-dark mt-2 mb-0"><%= analytics.totalHours %> ชม.</h2>
          <span class="text-muted text-xs"><i class="bi bi-info-circle me-1"></i>จากข้อมูลบันทึกทั้งหมด</span>
        </div>
        <div class="bg-hospital-light p-3 rounded-circle text-teal">
          <i class="bi bi-clock-history fs-3"></i>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card card-hospital p-4 border-0 bg-white h-100">
      <div class="d-flex align-items-center justify-content-between">
        <div>
          <span class="text-secondary text-xs fw-semibold uppercase tracking-wider">จำนวนผู้บันทึกงานวันนี้</span>
          <h2 class="fw-bold text-dark mt-2 mb-0"><%= analytics.activeUsersCount %> / <%= analytics.totalUsersCount %> คน</h2>
          <span class="text-muted text-xs">
            <% if (analytics.activeUsersCount === analytics.totalUsersCount && analytics.totalUsersCount > 0) { %>
              <span class="text-success"><i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i>ส่งครบทุกคนแล้ว</span>
            <% } else { %>
              <span class="text-warning"><i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i>ยังส่งไม่ครบทุกคน</span>
            <% } %>
          </span>
        </div>
        <div class="bg-hospital-light p-3 rounded-circle text-teal">
          <i class="bi bi-people-fill fs-3"></i>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-4">
    <div class="card card-hospital p-4 border-0 bg-white h-100">
      <div class="d-flex align-items-center justify-content-between">
        <div>
          <span class="text-secondary text-xs fw-semibold uppercase tracking-wider">บันทึกกิจกรรมวันนี้</span>
          <h2 class="fw-bold text-dark mt-2 mb-0"><%= analytics.activitiesLoggedToday %> กิจกรรม</h2>
          <span class="text-muted text-xs">
            เฉลี่ย <%= analytics.activeUsersCount > 0 ? (Math.round((analytics.activitiesLoggedToday / analytics.activeUsersCount) * 10) / 10) : 0 %> กิจกรรม/คนที่ส่ง
          </span>
        </div>
        <div class="bg-hospital-light p-3 rounded-circle text-teal">
          <i class="bi bi-journal-check fs-3"></i>
        </div>
      </div>
    </div>
  </div>

</div>

<!-- Charts Section Placeholder (As requested: Still no real charts until database integration is complete) -->
<div class="row g-4 mb-4">
  
  <div class="col-lg-7">
    <div class="card card-hospital border-0 p-4 bg-white h-100 d-flex flex-column align-items-center justify-content-center text-center py-5">
      <div class="bg-light rounded-circle p-4 mb-3 text-secondary">
        <i class="bi bi-bar-chart-line fs-1"></i>
      </div>
      <h5 class="fw-bold text-dark mb-2">แผนภูมิแสดงผลผลิตการปฏิบัติงาน</h5>
      <p class="text-secondary small mb-0" style="max-width: 400px;">
        ระบบจะเปิดใช้งานแผนภูมิภาพวิเคราะห์เส้นไทม์ไลน์โดยละเอียด เมื่อมีการเชื่อมต่อฐานข้อมูลและบันทึกประวัติการทำงานจริงมากกว่า 5 วันขึ้นไป
      </p>
    </div>
  </div>

  <div class="col-lg-5">
    <div class="card card-hospital border-0 p-4 bg-white h-100">
      <h5 class="fw-bold text-dark mb-3">สัดส่วนหมวดหมู่กิจกรรม (Department Share)</h5>
      
      <!-- Progress Bar Breakdown -->
      <div class="d-flex flex-column gap-3">
        <% if (analytics.categoryDistribution && analytics.categoryDistribution.length > 0) { %>
          <% analytics.categoryDistribution.forEach(function(item) { %>
            <div>
              <div class="d-flex justify-content-between text-sm mb-1">
                <span class="text-secondary"><%= item.name %></span>
                <span class="fw-bold text-dark"><%= item.percentage %>%</span>
              </div>
              <div class="progress rounded-pill" style="height: 8px;">
                <div class="progress-bar bg-teal" style="width: <%= item.percentage %>%;"></div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="text-center text-muted py-3 small">ไม่มีข้อมูลหมวดหมู่</div>
        <% } %>
      </div>
    </div>
  </div>

</div>

<!-- Team Active Work Status -->
<div class="row">
  <div class="col-12">
    <div class="card card-hospital border-0 bg-white">
      <div class="card-header bg-white border-0 py-3">
        <h5 class="fw-bold text-dark mb-0">สถานะบันทึกภาระงานของทีม</h5>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0 text-sm">
            <thead class="table-light">
              <tr>
                <th class="ps-4">ชื่อสมาชิก</th>
                <th>ตำแหน่งงาน</th>
                <th>จำนวนกิจกรรมที่ส่ง</th>
                <th>ชั่วโมงรวมวันนี้</th>
                <th class="pe-4">สถานะส่งงาน</th>
              </tr>
            </thead>
            <tbody>
              <% if (analytics.teamStatus && analytics.teamStatus.length > 0) { %>
                <% analytics.teamStatus.forEach(function(member) { %>
                  <tr>
                    <td class="ps-4 fw-semibold text-dark"><%= member.fullName %></td>
                    <td class="text-secondary"><%= member.position || '-' %></td>
                    <td><%= member.activityCount %> กิจกรรม</td>
                    <td><%= member.totalHours %> ชั่วโมง</td>
                    <td class="pe-4">
                      <% if (member.status === 'บันทึกเรียบร้อย') { %>
                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-2">บันทึกเรียบร้อย</span>
                      <% } else { %>
                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-2">ยังไม่บันทึก</span>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              <% } else { %>
                <tr>
                  <td colspan="5" class="text-center py-4 text-muted">ไม่มีข้อมูลของทีม</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
