<!-- Home: Quick Action & Record Screen -->
<div class="row g-4">
  
  <!-- Left Side: Capture First Quick Actions -->
  <div class="col-lg-8">
    
    <!-- Greeting Header -->
    <div class="card card-hospital border-0 p-4 mb-4" style="background: linear-gradient(135deg, #0D9488 0%, #0F766E 100%); color: white;">
      <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
          <h3 class="fw-bold mb-1" style="font-weight: 700;">สวัสดี, <%= typeof user !== 'undefined' ? user.fullName : 'คุณผู้ใช้งาน' %> 👋</h3>
          <p class="mb-0 opacity-90 small">
            <i class="bi bi-calendar3 me-1"></i>
            <%= new Date().toLocaleDateString('th-TH', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
          </p>
        </div>
        <div class="px-3 py-1.5 rounded-pill d-inline-flex align-items-center" style="background: rgba(255, 255, 255, 0.15); border: 1px solid rgba(255, 255, 255, 0.25); backdrop-filter: blur(8px);">
          <span class="small fw-semibold text-white" style="font-size: 0.75rem; letter-spacing: 0.05em;">
            <i class="bi bi-shield-check me-1"></i>ระบบบันทึกความดีและภาระงาน
          </span>
        </div>
      </div>
    </div>

    <!-- Quick Search & Main Log Button -->
    <div class="card card-hospital border-0 p-4 mb-4 bg-white position-relative">
      <div class="row align-items-center g-3">
        <div class="col-md-8 position-relative">
          <label class="form-label text-secondary small fw-semibold mb-2">🔍 พิมพ์ค้นหากิจกรรมหลักเพื่อบันทึกด่วน</label>
          <div class="input-group border rounded-3 overflow-hidden">
            <span class="input-group-text bg-white border-0 text-secondary pe-0"><i class="bi bi-search"></i></span>
            <input type="text" id="homeSearchInput" class="form-control border-0 ps-3" placeholder="เช่น แก้ไข HOSxP, ตรวจสอบ Backup, ซ่อมคอม..." autocomplete="off">
            <button class="btn btn-light border-0" type="button" onclick="clearHomeSearch()"><i class="bi bi-x-lg"></i></button>
          </div>
          <!-- Autocomplete Dropdown List -->
          <div id="homeAutocompleteList" class="search-autocomplete-list mt-2 d-none position-absolute w-100" style="z-index: 1000; left: 0;">
            <!-- Rendered by JS -->
          </div>
        </div>
        <div class="col-md-4 text-md-end d-flex align-items-end h-100" style="margin-top: auto;">
          <a href="/activity/create" class="btn btn-hospital w-100 py-2.5 shadow-sm">
            <i class="bi bi-plus-lg me-2"></i>บันทึกกิจกรรมใหม่
          </a>
        </div>
      </div>
    </div>

    <!-- Quick Actions (บันทึกด่วน) -->
    <div class="mb-4">
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="fw-bold text-dark mb-0">บันทึกด่วน (Quick Actions)</h5>
        <span class="text-muted small">แตะครั้งเดียวเพื่อบันทึก</span>
      </div>
      
      <div class="row g-3">
        <% 
          if (favorites && favorites.length > 0) {
            favorites.forEach(function(fav, index) { 
        %>
          <div class="col-md-4 col-sm-6">
            <div class="card card-hospital p-3 cursor-pointer d-flex flex-row align-items-center justify-content-between border hover-bg-light-subtle" onclick="openHomeQuickLog('<%= fav.id %>', '<%= fav.code %>: <%= fav.name.replace(/'/g, "\\'") %>')">
              <div class="d-flex align-items-center gap-3 w-100">
                <div class="bg-hospital-light text-teal rounded p-2 d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px;"><%= index + 1 %></div>
                <div class="text-truncate flex-grow-1">
                  <h6 class="fw-bold text-dark mb-0 text-truncate" title="<%= fav.name %>"><%= fav.name %></h6>
                </div>
              </div>
            </div>
          </div>
        <% 
            });
          } else { 
        %>
          <div class="col-12">
            <div class="p-3 text-muted small text-center border rounded border-dashed bg-white">ยังไม่มีบันทึกด่วน กรุณาไปที่หน้า <a href="/activity/create" class="text-teal text-decoration-none">บันทึกกิจกรรม</a> เพื่อปักหมุด</div>
          </div>
        <% } %>
      </div>
    </div>

    <!-- Recent Activity Timeline (Not Data Grid) -->
    <div>
      <div class="d-flex align-items-center justify-content-between mb-3">
        <h5 class="fw-bold text-dark mb-0">ประวัติกิจกรรมวันนี้ (Recent Activity)</h5>
        <a href="/activity" class="text-teal text-decoration-none small fw-semibold">ดูไทม์ไลน์ทั้งหมด</a>
      </div>
      
      <div class="card card-hospital border-0 p-4">
        <!-- Vertical timeline graphic line -->
        <div class="position-relative ps-4" style="border-left: 2px solid var(--border-color); margin-left: 10px;">
          <% if (recents && recents.length > 0) { %>
            <% recents.forEach(function(log, index) { %>
              <div class="position-relative mb-4">
                <!-- Timeline Dot Indicator -->
                <span class="position-absolute bg-teal rounded-circle border border-white" style="width: 12px; height: 12px; left: -31px; top: 6px; z-index: 2;"></span>
                
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                  <div>
                    <h6 class="fw-bold text-dark mb-1"><%= log.name %></h6>
                    <div class="d-flex align-items-center gap-2 flex-wrap text-secondary text-xs">
                      <%
                        const sessionMap = {
                          'Morning': 'ช่วงเช้า',
                          'Afternoon': 'ช่วงบ่าย',
                          'Night': 'ช่วงค่ำ/OT',
                          'AllDay': 'ทั้งวัน'
                        };
                        const sessionThai = sessionMap[log.session] || log.session;
                      %>
                      <span><i class="bi bi-clock me-1"></i><%= sessionThai %></span>
                      <% if (log.location) { %>
                        <span>•</span>
                        <span><i class="bi bi-geo-alt me-1"></i><%= log.location %></span>
                      <% } %>
                    </div>
                  </div>
                  <div>
                    <span class="badge bg-hospital-light text-teal"><%= log.duration %> นาที</span>
                  </div>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="text-center py-4 text-muted" style="margin-left: -20px;">
              <i class="bi bi-inbox fs-4 d-block mb-2"></i>
              วันนี้ยังไม่มีรายการกิจกรรมที่ถูกบันทึก
            </div>
          <% } %>
        </div>
      </div>
    </div>

  </div>

  <!-- Right Side: Today's Summary & Dashboard Snapshot -->
  <div class="col-lg-4">
    
    <!-- Today's Summary -->
    <div class="card card-hospital border-0 p-4 mb-4 bg-white">
      <h5 class="fw-bold text-dark mb-3">สรุปผลงานวันนี้ (Today's Summary)</h5>
      
      <div class="row g-2 mb-3">
        <div class="col-6">
          <div class="p-3 bg-light rounded-card text-center">
            <span class="text-secondary text-xs d-block mb-1">กิจกรรมวันนี้</span>
            <span class="fs-2 fw-bold text-dark"><%= summary.activityCount %></span>
            <span class="text-secondary text-xs d-block">งาน</span>
          </div>
        </div>
        <div class="col-6">
          <div class="p-3 bg-light rounded-card text-center">
            <span class="text-secondary text-xs d-block mb-1">เวลารวม</span>
            <span class="fs-2 fw-bold text-teal"><%= summary.totalHours %></span>
            <span class="text-secondary text-xs d-block">ชั่วโมง</span>
          </div>
        </div>
      </div>

      <div class="p-2.5 bg-success-subtle text-success text-xs rounded-card d-flex align-items-center gap-2">
        <i class="bi bi-lightning-fill"></i>
        <span>วันนี้ภาระงานผ่านเป้าหมายเฉลี่ยรายวันแล้ว!</span>
      </div>
    </div>

    <!-- Personal Workload Proportion Card -->
    <style>
      .category-drill-row {
        transition: all 0.2s ease-in-out;
        border: 1px solid transparent;
      }
      .category-drill-row:hover {
        background-color: #F8FAFC;
        transform: translateX(4px);
        border-color: #E2E8F0;
      }
    </style>
    
    <div class="card card-hospital border-0 p-4 shadow-sm" id="personalDistributionCard">
      <!-- Title Block -->
      <div class="mb-2">
        <h5 class="fw-bold text-dark mb-0" id="personalTitleText">สัดส่วนประเภทงานสะสมของคุณ</h5>
      </div>

      <!-- Date Range Selector in Card (Compact size) -->
      <div class="mb-3">
        <form action="/home" method="GET" id="homeFilterForm" class="d-flex flex-column gap-1">
          <select name="range" id="homeFilterRange" class="form-select form-select-sm rounded-3 border-secondary-subtle" onchange="onHomeRangeChange(this.value)">
            <option value="today" <%= query.range === 'today' ? 'selected' : '' %>>วันนี้ (Today)</option>
            <option value="week" <%= query.range === 'week' ? 'selected' : '' %>>ย้อนหลัง 7 วัน</option>
            <option value="month" <%= query.range === 'month' ? 'selected' : '' %>>ย้อนหลัง 30 วัน</option>
            <option value="custom" <%= query.range === 'custom' ? 'selected' : '' %>>กำหนดเอง (Custom)</option>
          </select>
          
          <div id="homeCustomDateContainer" class="<%= query.range === 'custom' ? '' : 'd-none' %> d-flex align-items-center gap-1 mt-1 flex-wrap">
            <input type="date" class="form-control form-control-sm rounded-3 py-0.5" style="font-size: 11px;" id="homeFilterStart" name="start" value="<%= query.start %>" required>
            <span class="text-xs text-muted">ถึง</span>
            <input type="date" class="form-control form-control-sm rounded-3 py-0.5" style="font-size: 11px;" id="homeFilterEnd" name="end" value="<%= query.end %>" required>
            <button type="submit" class="btn btn-sm btn-teal py-0.5 px-2 rounded-3 text-xs"><i class="bi bi-search"></i></button>
          </div>
        </form>
      </div>
      
      <!-- Back Button (Hidden by default) -->
      <div id="personalBackBtnContainer" class="d-none mb-3">
        <button onclick="handlePersonalBack()" class="btn btn-sm btn-link text-teal p-0 text-decoration-none fw-bold">
          <i class="bi bi-arrow-left me-1"></i> ย้อนกลับ
        </button>
      </div>

      <!-- Categories Container -->
      <div id="personalCategoriesContainer" class="d-flex flex-column gap-3">
        <% if (personalDistribution && personalDistribution.length > 0) { %>
          <div class="text-muted text-xs mb-1" style="font-size: 10px;"><i class="bi bi-info-circle me-1"></i>คลิกหมวดหมู่หลักเพื่อดูสัดส่วนกลุ่มกิจกรรมย่อย</div>
          <% personalDistribution.forEach(function(item, index) { %>
            <div class="category-drill-row p-1.5 rounded-2" style="cursor: pointer;" onclick="drillDownPersonalGroups('<%= index %>')">
              <div class="d-flex justify-content-between text-xs mb-1">
                <span class="text-secondary fw-semibold"><%= item.name %> <i class="bi bi-chevron-right text-muted text-xs ms-0.5"></i></span>
                <span class="fw-bold text-dark"><%= item.percentage %>%</span>
              </div>
              <div class="progress rounded-pill" style="height: 6px;">
                <div class="progress-bar bg-teal" style="width: <%= item.percentage %>%;"></div>
              </div>
            </div>
          <% }); %>
        <% } else { %>
          <div class="text-center text-muted py-4 small"><i class="bi bi-inbox me-1"></i>ไม่มีข้อมูลสัดส่วนกิจกรรม</div>
        <% } %>
      </div>

      <!-- Activities/Groups Drilldown Container (Hidden by default) -->
      <div id="personalDrilldownContainer" class="d-none d-flex flex-column gap-3">
        <!-- Will be populated dynamically via Javascript -->
      </div>

      <div class="mt-4 pt-3 border-top text-center">
        <a href="/dashboard?range=<%= query.range %>&start=<%= query.start %>&end=<%= query.end %>" class="text-teal text-decoration-none small fw-semibold">
          เปิดสถิติวิเคราะห์โดยละเอียด <i class="bi bi-arrow-right ms-1"></i>
        </a>
      </div>
    </div>

  </div>
</div>

<!-- Floating Action Button (FAB - Mobile Only) -->
<a href="#" class="fab d-lg-none shadow" onclick="triggerMobileQuickLog()">
  <i class="bi bi-plus-lg"></i>
</a>

<!-- Home Quick Log Modal (Google Keep style) -->
<div class="modal fade" id="homeQuickLogModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 480px;">
    <div class="modal-content border-0 rounded-card shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="fw-bold text-dark">บันทึกกิจกรรมด่วน</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      
      <form action="/activity/create" method="POST" class="needs-validation" novalidate id="homeQuickLogForm">
        <div class="modal-body py-3">
          <input type="hidden" id="homeQuickActivityId" name="activityMasterId" required>
          
          <div class="mb-3">
            <label class="form-label text-secondary small fw-semibold">กิจกรรม</label>
            <input type="text" class="form-control rounded-3 bg-light border-0 fw-bold" id="homeQuickActivityName" readonly>
          </div>

          <!-- Date Selection (วันนี้ / ย้อนหลัง 1 วัน / เลือกเอง) -->
          <div class="mb-3">
            <label class="form-label text-secondary small fw-semibold">วันที่ปฏิบัติงาน</label>
            <div class="segmented-control mb-2" id="homeDateGroup">
              <button type="button" class="chip-btn active" onclick="setHomeDateMode('today', this)">วันนี้</button>
              <button type="button" class="chip-btn" onclick="setHomeDateMode('yesterday', this)">ย้อนหลัง 1 วัน</button>
              <button type="button" class="chip-btn" onclick="setHomeDateMode('custom', this)">เลือกวันที่เอง</button>
            </div>
            <div id="homeLogDateContainer" class="d-none mt-2">
              <input type="date" name="logDate" id="homeLogDate" class="form-control rounded-3">
            </div>
          </div>

          <!-- Session selection -->
          <div class="mb-3">
            <label class="form-label text-secondary small fw-semibold">ช่วงเวลาทำงาน</label>
            <div class="segmented-control" id="homeSessionGroup">
              <button type="button" class="chip-btn active" onclick="setHomeSession('Morning', this)">เช้า</button>
              <button type="button" class="chip-btn" onclick="setHomeSession('Afternoon', this)">บ่าย</button>
              <button type="button" class="chip-btn" onclick="setHomeSession('Night', this)">ค่ำ/OT</button>
              <button type="button" class="chip-btn" onclick="setHomeSession('AllDay', this)">ทั้งวัน</button>
            </div>
            <input type="hidden" name="session" id="homeSelectedSession" value="Morning">
          </div>

          <!-- Duration selection chips -->
          <div class="mb-3">
            <label class="form-label text-secondary small fw-semibold">ระยะเวลาที่ใช้ (นาที)</label>
            <div class="segmented-control mb-2" id="homeDurationGroup">
              <button type="button" class="chip-btn" onclick="setHomeDuration(15, this)">15 นาที</button>
              <button type="button" class="chip-btn active" onclick="setHomeDuration(30, this)">30 นาที</button>
              <button type="button" class="chip-btn" onclick="setHomeDuration(60, this)">60 นาที</button>
              <button type="button" class="chip-btn" onclick="setHomeDuration(120, this)">120 นาที</button>
            </div>
            <div class="input-group input-group-sm mt-2">
              <span class="input-group-text bg-light text-secondary border-0">ระบุเอง</span>
              <input type="number" name="duration" id="homeSelectedDuration" class="form-control" value="30" min="1" required placeholder="นาที">
            </div>
          </div>

          <!-- Location selection -->
          <div class="mb-3">
            <label for="homeLocation" class="form-label text-secondary small fw-semibold">สถานที่</label>
            <select class="form-select rounded-3" id="homeLocation" name="locationId">
              <option value="">เลือกสถานที่...</option>
              <% if (typeof locations !== 'undefined' && locations.length > 0) { %>
                <% locations.forEach(function(loc) { %>
                  <% const isDefault = loc.name.includes('กลุ่มงานดิจิทัล') || loc.name.includes('ดิจิทัล'); %>
                  <option value="<%= loc.id %>" <%= isDefault ? 'selected' : '' %>><%= loc.name %></option>
                <% }); %>
              <% } else { %>
                <option value="1">OPD (แผนกผู้ป่วยนอก)</option>
                <option value="2">ER (ห้องฉุกเฉิน)</option>
                <option value="3">IPD (แผนกผู้ป่วยใน)</option>
                <option value="4">LAB (ห้องปฏิบัติการ)</option>
                <option value="5">ห้องเซิร์ฟเวอร์</option>
                <option value="6">ห้องประชุม</option>
              <% } %>
            </select>
          </div>

          <!-- Output -->
          <div class="mb-3">
            <label for="homeOutput" class="form-label text-secondary small fw-semibold">ผลงาน / ผลลัพธ์</label>
            <textarea class="form-control rounded-3" id="homeOutput" name="output" rows="2" placeholder="อธิบายผลงาน..."></textarea>
          </div>

          <!-- Remark -->
          <div class="mb-3">
            <label for="homeRemark" class="form-label text-secondary small fw-semibold">หมายเหตุ</label>
            <textarea class="form-control rounded-3" id="homeRemark" name="remark" rows="1" placeholder="ความเห็นเพิ่มเติม..."></textarea>
          </div>
        </div>

        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-hospital rounded-3 px-4">บันทึกทันที</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Dynamic data container for client-side JavaScript -->
<div id="home-activities-data" data-activities="<%= typeof activities !== 'undefined' ? JSON.stringify(activities.map(act => ({ id: act.id.toString(), name: `${act.code}: ${act.name}` }))) : '[]' %>"></div>

<script>
  let homeQuickModal;
  const masterActivities = JSON.parse(document.getElementById('home-activities-data').dataset.activities);

  document.addEventListener('DOMContentLoaded', () => {
    if (typeof bootstrap !== 'undefined') {
      homeQuickModal = new bootstrap.Modal(document.getElementById('homeQuickLogModal'));
    }
    
    // Autocomplete logic for Home search bar
    const searchInput = document.getElementById('homeSearchInput');
    const autocompleteList = document.getElementById('homeAutocompleteList');

    searchInput.addEventListener('input', () => {
      const value = searchInput.value.toLowerCase().trim();
      if (!value) {
        autocompleteList.classList.add('d-none');
        return;
      }

      const matches = masterActivities.filter(act => act.name.toLowerCase().includes(value));
      
      if (matches.length > 0) {
        autocompleteList.innerHTML = matches.map(match => `
          <div class="search-autocomplete-item" onclick="openHomeQuickLog(${match.id}, '${match.name.replace(/'/g, "\\'")}')">
            <span class="fw-semibold text-dark">${match.name}</span>
          </div>
        `).join('');
        autocompleteList.classList.remove('d-none');
      } else {
        autocompleteList.innerHTML = `<div class="p-3 text-muted small text-center">ไม่พบกิจกรรมหลัก กรุณาลองคำค้นอื่น</div>`;
        autocompleteList.classList.remove('d-none');
      }
    });

    // Close autocomplete on click outside
    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !autocompleteList.contains(e.target)) {
        autocompleteList.classList.add('d-none');
      }
    });

    // Warning popup for exceeding 7 hours
    const form = document.getElementById('homeQuickLogForm');
    if (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
          form.classList.add('was-validated');
          return;
        }

        // Prevent default submit first to show Swal
        event.preventDefault();

        const todayTotal = <%= typeof summary !== 'undefined' && summary.totalMinutes !== 'undefined' ? summary.totalMinutes : 0 %>;
        const durationInput = document.getElementById('homeSelectedDuration');
        const durationVal = parseInt(durationInput?.value || 0, 10);
        const projectedTotal = todayTotal + durationVal;

        if (projectedTotal > 420) {
          Swal.fire({
            title: 'เวลาทำงานสะสมเกิน 7 ชั่วโมง',
            html: `วันนี้คุณบันทึกเวลาทำงานสะสมไปแล้ว <strong>${todayTotal} นาที</strong><br>` +
                  `และรายการนี้ระบุ <strong>${durationVal} นาที</strong><br>` +
                  `ทำให้เวลารวมสะสมเป็น <strong>${projectedTotal} นาที</strong> (~${(projectedTotal/60).toFixed(1)} ชม.)<br><br>` +
                  `คุณแน่ใจหรือไม่ว่าใส่ระยะเวลาถูกต้องแล้ว?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#0D9488',
            cancelButtonColor: '#94A3B8',
            confirmButtonText: 'ใช่ บันทึกเลย',
            cancelButtonText: 'ยกเลิกเพื่อแก้ไข'
          }).then((result) => {
            if (result.isConfirmed) {
              form.classList.add('was-validated');
              form.submit();
            }
          });
        } else {
          form.classList.add('was-validated');
          form.submit();
        }
      });
    }
  });

  function clearHomeSearch() {
    document.getElementById('homeSearchInput').value = '';
    document.getElementById('homeAutocompleteList').classList.add('d-none');
  }

  function openHomeQuickLog(id, name) {
    document.getElementById('homeQuickActivityId').value = id;
    document.getElementById('homeQuickActivityName').value = name;
    
    // Set defaults
    setHomeSession('Morning', document.querySelector('#homeSessionGroup .chip-btn:first-child'));
    setHomeDuration(30, document.querySelector('#homeDurationGroup .chip-btn:nth-child(2)'));
    setHomeDateMode('today', document.querySelector('#homeDateGroup .chip-btn:first-child'));
    
    // Clear autocomplete list
    document.getElementById('homeAutocompleteList').classList.add('d-none');
    
    homeQuickModal.show();
  }

  function setHomeDateMode(mode, element) {
    const btns = document.querySelectorAll('#homeDateGroup .chip-btn');
    btns.forEach(btn => btn.classList.remove('active'));
    element.classList.add('active');

    const dateContainer = document.getElementById('homeLogDateContainer');
    const dateInput = document.getElementById('homeLogDate');
    
    const today = new Date();
    const getLocalDateString = () => {
      const year = today.getFullYear();
      const month = String(today.getMonth() + 1).padStart(2, '0');
      const day = String(today.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    };

    if (mode === 'today') {
      dateContainer.classList.add('d-none');
      dateInput.value = getLocalDateString();
    } else if (mode === 'yesterday') {
      dateContainer.classList.add('d-none');
      const yesterday = new Date(today);
      yesterday.setDate(yesterday.getDate() - 1);
      const yYear = yesterday.getFullYear();
      const yMonth = String(yesterday.getMonth() + 1).padStart(2, '0');
      const yDay = String(yesterday.getDate()).padStart(2, '0');
      dateInput.value = `${yYear}-${yMonth}-${yDay}`;
    } else if (mode === 'custom') {
      dateContainer.classList.remove('d-none');
      if (!dateInput.value) {
        dateInput.value = getLocalDateString();
      }
    }
  }

  function triggerMobileQuickLog() {
    // FAB tap default behavior is to select the first active item or trigger modal directly
    openHomeQuickLog(1, 'ACT-001: ซ่อมและแก้ไขอุปกรณ์คอมพิวเตอร์ (Hardware Repair)');
  }

  function setHomeSession(value, element) {
    document.getElementById('homeSelectedSession').value = value;
    const btns = document.querySelectorAll('#homeSessionGroup .chip-btn');
    btns.forEach(btn => btn.classList.remove('active'));
    element.classList.add('active');
    
    const durationInput = document.getElementById('homeSelectedDuration');
    const durationGroup = document.getElementById('homeDurationGroup');
    
    if (value === 'AllDay') {
      if (durationInput) {
        durationInput.value = '420';
        durationInput.readOnly = true;
        durationInput.classList.add('bg-light');
      }
      if (durationGroup) {
        durationGroup.querySelectorAll('.chip-btn').forEach(btn => {
          btn.classList.remove('active');
          btn.disabled = true;
        });
      }
    } else {
      if (durationInput) {
        durationInput.readOnly = false;
        durationInput.classList.remove('bg-light');
        if (durationInput.value === '420') {
          durationInput.value = '30';
          // Set active chip for 30 mins
          const chip30 = durationGroup?.querySelector('.chip-btn:nth-child(2)');
          if (chip30) chip30.classList.add('active');
        }
      }
      if (durationGroup) {
        durationGroup.querySelectorAll('.chip-btn').forEach(btn => {
          btn.disabled = false;
        });
      }
    }
  }

  function setHomeDuration(value, element) {
    document.getElementById('homeSelectedDuration').value = value;
    const btns = document.querySelectorAll('#homeDurationGroup .chip-btn');
    btns.forEach(btn => btn.classList.remove('active'));
    element.classList.add('active');
  }

  // Personal 3-level workload drill-down logic
  const PERSONAL_DATA = <%- JSON.stringify(personalDistribution) %>;
  let homeCatIndex = null;
  let homeGrpIndex = null;

  function onHomeRangeChange(value) {
    const customContainer = document.getElementById('homeCustomDateContainer');
    if (value === 'custom') {
      customContainer.classList.remove('d-none');
    } else {
      customContainer.classList.add('d-none');
      document.getElementById('homeFilterForm').submit();
    }
  }

  function drillDownPersonalGroups(catIndex) {
    homeCatIndex = parseInt(catIndex, 10);
    homeGrpIndex = null;
    const category = PERSONAL_DATA[homeCatIndex];
    if (!category) return;

    // Change title text
    document.getElementById('personalTitleText').innerHTML = `<i class="bi bi-tag-fill me-1 text-teal"></i> กลุ่มย่อย: ${category.name}`;
    
    // Hide categories container and show back button
    document.getElementById('personalCategoriesContainer').classList.add('d-none');
    document.getElementById('personalBackBtnContainer').classList.remove('d-none');
    
    // Populate activities drilldown container with Groups list (Level 2)
    const container = document.getElementById('personalDrilldownContainer');
    container.innerHTML = '';
    
    if (category.groups && category.groups.length > 0) {
      const infoText = document.createElement('div');
      infoText.className = 'text-muted text-xs mb-1';
      infoText.style.fontSize = '10px';
      infoText.innerHTML = '<i class="bi bi-info-circle me-1"></i>คลิกกลุ่มกิจกรรมย่อยเพื่อดูสัดส่วนกิจกรรมย่อย';
      container.appendChild(infoText);

      category.groups.forEach((group, grpIndex) => {
        const groupEl = document.createElement('div');
        groupEl.className = 'category-drill-row p-1.5 rounded-2';
        groupEl.style.cursor = 'pointer';
        groupEl.onclick = () => drillDownPersonalActivities(grpIndex);
        groupEl.innerHTML = `
          <div class="d-flex justify-content-between text-xs mb-1">
            <span class="text-secondary fw-semibold">${group.name} <i class="bi bi-chevron-right text-muted text-xs ms-0.5"></i></span>
            <span class="fw-bold text-teal">${group.percentage}%</span>
          </div>
          <div class="progress rounded-pill" style="height: 6px;">
            <div class="progress-bar bg-teal bg-opacity-75" style="width: ${group.percentage}%;"></div>
          </div>
        `;
        container.appendChild(groupEl);
      });
    } else {
      container.innerHTML = '<div class="text-center text-muted py-4 small"><i class="bi bi-inbox me-1"></i>ไม่มีข้อมูลกลุ่มกิจกรรมย่อย</div>';
    }

    container.classList.remove('d-none');
  }

  function drillDownPersonalActivities(grpIndex) {
    homeGrpIndex = parseInt(grpIndex, 10);
    const category = PERSONAL_DATA[homeCatIndex];
    if (!category) return;
    const group = category.groups[homeGrpIndex];
    if (!group) return;

    // Change title text
    document.getElementById('personalTitleText').innerHTML = `<i class="bi bi-tag-fill me-1 text-info"></i> กิจกรรมย่อย: ${group.name}`;
    
    // Populate activities drilldown container with Activities list (Level 3)
    const container = document.getElementById('personalDrilldownContainer');
    container.innerHTML = '';
    
    if (group.activities && group.activities.length > 0) {
      group.activities.forEach(act => {
        const actEl = document.createElement('div');
        actEl.className = 'p-1.5 rounded-2';
        actEl.innerHTML = `
          <div class="d-flex justify-content-between text-xs mb-1">
            <span class="text-secondary fw-semibold">${act.name}</span>
            <span class="fw-bold text-info">${act.percentage}%</span>
          </div>
          <div class="progress rounded-pill" style="height: 6px;">
            <div class="progress-bar bg-info bg-opacity-75" style="width: ${act.percentage}%;"></div>
          </div>
        `;
        container.appendChild(actEl);
      });
    } else {
      container.innerHTML = '<div class="text-center text-muted py-4 small"><i class="bi bi-inbox me-1"></i>ไม่มีข้อมูลกิจกรรมย่อย</div>';
    }
  }

  function handlePersonalBack() {
    if (homeGrpIndex !== null) {
      // Go back to groups (Level 2)
      drillDownPersonalGroups(homeCatIndex);
    } else {
      // Go back to categories (Level 1)
      showPersonalCategories();
    }
  }

  function showPersonalCategories() {
    homeCatIndex = null;
    homeGrpIndex = null;
    
    // Restore default title text
    document.getElementById('personalTitleText').innerText = 'สัดส่วนประเภทงานสะสมของคุณ';
    
    // Hide back button and sub-groups container
    document.getElementById('personalBackBtnContainer').classList.add('d-none');
    document.getElementById('personalDrilldownContainer').classList.add('d-none');
    
    // Show categories container
    document.getElementById('personalCategoriesContainer').classList.remove('d-none');
  }

  // Initialize custom date container if custom range is active on page load
  document.addEventListener('DOMContentLoaded', function () {
    const rangeSelect = document.getElementById('homeFilterRange');
    const customContainer = document.getElementById('homeCustomDateContainer');
    if (rangeSelect && rangeSelect.value === 'custom' && customContainer) {
      customContainer.classList.remove('d-none');
    }
  });
</script>
