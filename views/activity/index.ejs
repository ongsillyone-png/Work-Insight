<!-- Facebook / Git Timeline Style View for Activity History -->
<style>
  .timeline-card {
    transition: all 0.2s ease-in-out;
    cursor: pointer;
    border-left: 3px solid transparent !important;
  }
  .timeline-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.05), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
    border-left: 3px solid var(--hospital-teal) !important;
    background-color: #FAFAFA !important;
  }
</style>
<div class="row g-4">
  
  <!-- Left Side: Timeline Feed -->
  <div class="col-lg-8">
    
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
      <div>
        <h3 class="fw-bold text-dark mb-1">ประวัติการปฏิบัติงาน (Timeline)</h3>
        <p class="text-secondary small">ตรวจสอบบันทึกภาระงานและลำดับขั้นตอนกิจกรรมย้อนหลัง</p>
      </div>
      <div>
        <a href="/activity/create" class="btn btn-hospital shadow-sm">
          <i class="bi bi-plus-lg me-2"></i>บันทึกกิจกรรมใหม่
        </a>
      </div>
    </div>

    <!-- Timeline Container -->
    <div class="position-relative ps-4" style="border-left: 2px solid var(--border-color); margin-left: 20px;">
      
      <% if (logs && logs.length > 0) { %>
        <!-- Group logs by date -->
        <% 
          let currentDate = ""; 
          let isFirst = true;
          logs.forEach(function(log, idx) { 
            if (log.date !== currentDate) {
              currentDate = log.date;
              if (!isFirst) { 
        %>
                </div> <!-- Close previous day content wrapper -->
                </div> <!-- Close previous day container -->
        <% 
              } 
              isFirst = false;
        %>
              <!-- Day Container -->
              <div class="day-group mb-4" id="group-<%= log.date %>">
                <!-- Date Node Header (Clickable for collapse) -->
                <% const isLatest = (latestDate && log.date === latestDate); %>
                <div class="position-relative my-3" style="margin-left: -32px; cursor: pointer; user-select: none;" onclick="toggleDayCollapse('<%= log.date %>')">
                  <div class="bg-hospital-light text-teal border border-teal rounded-pill px-3 py-1 d-inline-flex align-items-center fw-bold shadow-sm" style="font-size: 0.85rem; border-color: var(--hospital-teal) !important;">
                    <i class="bi bi-calendar-check me-2"></i>
                    <span><%= log.date %></span>
                    <i class="bi bi-<%= isLatest ? 'chevron-down' : 'chevron-right' %> ms-2 collapse-icon" id="icon-<%= log.date %>"></i>
                  </div>
                </div>
                <!-- Day Content Wrapper -->
                <div class="day-content" id="content-<%= log.date %>" style="transition: all 0.2s ease-in-out; <%= isLatest ? '' : 'display: none;' %>">
        <% 
            } 
        %>

            <!-- Timeline Activity Card -->
            <div class="position-relative mb-4">
              <!-- Timeline Marker Icon -->
              <span class="position-absolute bg-teal rounded-circle d-flex align-items-center justify-content-center text-white" style="width: 24px; height: 24px; left: -33px; top: 12px; border: 3px solid #F8FAFC; z-index: 2;">
                <i class="bi bi-dot" style="font-size: 1.25rem;"></i>
              </span>

              <!-- Content Card -->
              <div class="card card-hospital p-3 border-0 bg-white shadow-sm timeline-card" onclick="window.location.href='/activity/edit/<%= log.id %>'">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                  <div>
                    <h6 class="fw-bold text-dark mb-1"><%= log.activityName %></h6>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                      <span class="badge bg-hospital-light"><%= log.session %></span>
                      <span class="text-secondary text-xs"><i class="bi bi-clock me-1"></i><%= log.duration %> นาที</span>
                      <% if (log.location) { %>
                        <span class="text-secondary text-xs"><i class="bi bi-geo-alt me-1"></i><%= log.location %></span>
                      <% } %>
                    </div>
                  </div>
                  
                  <!-- Actions Button Group -->
                  <div class="d-flex gap-1">
                    <a href="/activity/edit/<%= log.id %>" class="btn btn-light btn-sm rounded-circle p-1.5" title="แก้ไข" onclick="event.stopPropagation();">
                      <i class="bi bi-pencil text-secondary" style="font-size: 0.9rem;"></i>
                    </a>
                    <button class="btn btn-light btn-sm rounded-circle p-1.5 btn-delete" data-id="<%= log.id %>" title="ลบ" onclick="event.stopPropagation();">
                      <i class="bi bi-trash text-danger" style="font-size: 0.9rem;"></i>
                    </button>
                  </div>
                </div>

                <!-- Deliverable / Outcome details -->
                <% if (log.output) { %>
                  <div class="p-2 bg-light rounded-card text-sm text-dark mb-2">
                    <strong class="text-xs text-secondary d-block mb-1">ผลงาน / ผลลัพธ์:</strong>
                    <%= log.output %>
                  </div>
                <% } %>

                <!-- Additional Remarks -->
                <% if (log.remark) { %>
                  <p class="text-xs text-secondary mb-0 italic">
                    <i class="bi bi-chat-left-dots me-1"></i>หมายเหตุ: <%= log.remark %>
                  </p>
                <% } %>
              </div>
            </div>

        <% }); %>
          </div> <!-- Close last day content wrapper -->
          </div> <!-- Close last day container -->
      <% } else { %>
        <!-- Empty State Container -->
        <div class="text-center py-5 text-muted bg-white rounded-card shadow-sm border p-4" style="margin-left: -20px;">
          <i class="bi bi-journal-x fs-1 text-secondary d-block mb-3"></i>
          <h5 class="fw-bold text-dark">ยังไม่มีบันทึกประวัติการทำงาน</h5>
          <p class="text-secondary small mb-3">เริ่มต้นบันทึกกิจกรรมแรกของคุณเพื่อสร้างไทม์ไลน์ประวัติการทำงาน!</p>
          <a href="/activity/create" class="btn btn-hospital px-4">
            <i class="bi bi-plus-lg me-1"></i>บันทึกงานแรก
          </a>
        </div>
      <% } %>

    </div>

    <!-- Pagination Navigator -->
    <% if (locals.pagination && pagination.totalPages > 1) { %>
      <nav aria-label="Timeline navigation" class="mt-4">
        <ul class="pagination justify-content-center gap-1">
          <!-- Previous Button -->
          <li class="page-item <%= pagination.currentPage === 1 ? 'disabled' : '' %>">
            <% 
              let prevQuery = { ...query }; 
              prevQuery.page = pagination.currentPage - 1;
              let prevUrl = '/activity?' + new URLSearchParams(prevQuery).toString();
            %>
            <a class="page-link rounded-3 border px-3 py-2 text-teal fw-semibold shadow-sm" href="<%= prevUrl %>" aria-label="Previous">
              &laquo; ก่อนหน้า
            </a>
          </li>

          <!-- Page Numbers -->
          <% for (let i = 1; i <= pagination.totalPages; i++) { %>
            <% 
              let pageQuery = { ...query }; 
              pageQuery.page = i;
              let pageUrl = '/activity?' + new URLSearchParams(pageQuery).toString();
              let isActive = pagination.currentPage === i;
            %>
            <li class="page-item">
              <a class="page-link rounded-3 border px-3 py-2 fw-semibold shadow-sm <%= isActive ? 'bg-teal border-teal text-white' : 'text-teal' %>" href="<%= pageUrl %>">
                <%= i %>
              </a>
            </li>
          <% } %>

          <!-- Next Button -->
          <li class="page-item <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>">
            <% 
              let nextQuery = { ...query }; 
              nextQuery.page = pagination.currentPage + 1;
              let nextUrl = '/activity?' + new URLSearchParams(nextQuery).toString();
            %>
            <a class="page-link rounded-3 border px-3 py-2 text-teal fw-semibold shadow-sm" href="<%= nextUrl %>" aria-label="Next">
              ถัดไป &raquo;
            </a>
          </li>
        </ul>
      </nav>
    <% } %>

  </div>

  <!-- Right Side: Sidebar Filters (Todoist-style Filters) -->
  <div class="col-lg-4">
    <div class="card card-hospital border-0 p-4 bg-white shadow-sm position-sticky" style="top: 84px;">
      <h5 class="fw-bold text-dark mb-3">ค้นหาและกรองประวัติ</h5>
      
      <form class="d-flex flex-column gap-3" action="/activity" method="GET">
        <!-- Date -->
        <div>
          <label for="filterDate" class="form-label text-secondary small fw-semibold">เลือกวันที่</label>
          <input type="date" class="form-control rounded-3" id="filterDate" name="date" value="<%= (locals.query && locals.query.date) || '' %>">
        </div>

        <!-- Session selection -->
        <div>
          <label for="filterSession" class="form-label text-secondary small fw-semibold">ช่วงเวลาทำงาน</label>
          <select class="form-select rounded-3" id="filterSession" name="session">
            <option value="" <%= (locals.query && !locals.query.session) ? 'selected' : '' %>>ทุกช่วงเวลา</option>
            <option value="Morning" <%= (locals.query && locals.query.session === 'Morning') ? 'selected' : '' %>>เช้า</option>
            <option value="Afternoon" <%= (locals.query && locals.query.session === 'Afternoon') ? 'selected' : '' %>>บ่าย</option>
            <option value="Night" <%= (locals.query && locals.query.session === 'Night') ? 'selected' : '' %>>ค่ำ</option>
            <option value="AllDay" <%= (locals.query && locals.query.session === 'AllDay') ? 'selected' : '' %>>ทั้งวัน</option>
          </select>
        </div>

        <!-- Search input query -->
        <div>
          <label for="filterSearch" class="form-label text-secondary small fw-semibold">คำค้นหา</label>
          <div class="input-group input-group-sm border rounded-3 overflow-hidden">
            <span class="input-group-text bg-light border-0"><i class="bi bi-search text-secondary"></i></span>
            <input type="text" class="form-control border-0" id="filterSearch" name="search" placeholder="ค้นหาชื่อผลงาน, กิจกรรม..." value="<%= (locals.query && locals.query.search) || '' %>">
          </div>
        </div>

        <!-- Submission buttons -->
        <div class="d-grid gap-2 pt-2">
          <button type="submit" class="btn btn-hospital">
            <i class="bi bi-filter me-1"></i>กรองข้อมูล
          </button>
          <a href="/activity" class="btn btn-light border rounded-3 text-center">
            ล้างตัวกรอง
          </a>
        </div>
      </form>
    </div>
  </div>

</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Show SweetAlert success notifications if query param is set
    const urlParams = new URLSearchParams(window.location.search);
    const successType = urlParams.get('success');
    if (successType) {
      let title = 'ดำเนินการสำเร็จ!';
      let text = 'บันทึกข้อมูลเรียบร้อยแล้ว';
      if (successType === 'create') {
        title = 'บันทึกสำเร็จ!';
        text = 'เพิ่มประวัติกิจกรรมการทำงานใหม่เรียบร้อยแล้ว';
      } else if (successType === 'update') {
        title = 'แก้ไขสำเร็จ!';
        text = 'ปรับปรุงข้อมูลประวัติการทำงานเรียบร้อยแล้ว';
      }
      
      Swal.fire({
        title: title,
        text: text,
        icon: 'success',
        timer: 2000,
        showConfirmButton: false
      });

      // Clear the query parameter without reloading the page
      urlParams.delete('success');
      const newUrl = window.location.pathname + (urlParams.toString() ? '?' + urlParams.toString() : '');
      window.history.replaceState({}, '', newUrl);
    }

    // Delete validation using SweetAlert2
    const deleteButtons = document.querySelectorAll('.btn-delete');
    deleteButtons.forEach(btn => {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        const id = this.getAttribute('data-id');
        Swal.fire({
          title: 'คุณแน่ใจหรือ?',
          text: 'คุณต้องการลบบันทึกประวัติกิจกรรมการทำงานนี้หรือไม่?',
          icon: 'warning',
          showCancelButton: true,
          confirmButtonColor: '#0D9488',
          cancelButtonColor: '#EF4444',
          confirmButtonText: 'ใช่ ลบเลย!',
          cancelButtonText: 'ยกเลิก'
        }).then((result) => {
            fetch(`/activity/delete/${id}`, { method: 'DELETE' })
              .then(res => res.json())
              .then(data => {
                if (data.success) {
                  Swal.fire({
                    title: 'ลบแล้ว!',
                    text: 'บันทึกประวัติการทำงานถูกลบเรียบร้อยแล้ว',
                    icon: 'success',
                    timer: 1500,
                    showConfirmButton: false
                  }).then(() => window.location.reload());
                } else {
                  Swal.fire('ผิดพลาด!', data.message || 'ลบข้อมูลไม่สำเร็จ', 'error');
                }
              })
              .catch(err => {
                Swal.fire('ผิดพลาด!', 'เกิดข้อผิดพลาดในการเชื่อมต่อ', 'error');
              });
        });
      });
    });
  });

  function toggleDayCollapse(date) {
    const content = document.getElementById('content-' + date);
    const icon = document.getElementById('icon-' + date);
    if (content && icon) {
      if (content.style.display === 'none') {
        content.style.display = 'block';
        icon.classList.remove('bi-chevron-right');
        icon.classList.add('bi-chevron-down');
      } else {
        content.style.display = 'none';
        icon.classList.remove('bi-chevron-down');
        icon.classList.add('bi-chevron-right');
      }
    }
  }
</script>
