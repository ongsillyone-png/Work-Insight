<!-- Notion & Todoist style Quick Capture Interface -->
<div class="row">
  <div class="col-lg-8 mx-auto">
    
    <!-- Header -->
    <div class="mb-4 text-center">
      <h3 class="fw-bold text-dark mb-1">บันทึกกิจกรรมประจำวัน</h3>
      <p class="text-secondary small">ป้อนงานและระยะเวลาปฏิบัติงานของวันนี้อย่างรวดเร็ว</p>
    </div>

    <!-- Search Input Autocomplete Box (Notion Quick Find style) -->
    <div class="card card-hospital border-0 p-4 mb-4">
      <label class="form-label text-secondary small fw-semibold mb-2">ค้นหากิจกรรมที่ต้องการบันทึก</label>
      <div class="input-group input-group-lg shadow-sm rounded-3 overflow-hidden border">
        <span class="input-group-text bg-white border-0 text-secondary pe-0"><i class="bi bi-search"></i></span>
        <input type="text" id="activitySearchInput" class="form-control border-0 ps-3" style="font-size: 1rem;" placeholder="พิมพ์ค้นหากิจกรรม เช่น ซ่อมคอม, database, backup, HOSxP, ประชุม..." autocomplete="off">
        <button class="btn btn-light border-0 px-3" type="button" onclick="clearSearch()"><i class="bi bi-x-lg"></i></button>
      </div>

      <!-- Autocomplete Dropdown List -->
      <div id="searchAutocompleteList" class="search-autocomplete-list mt-2 d-none">
        <!-- Matching items rendered via JavaScript -->
      </div>
    </div>

    <!-- Quick Actions Section -->
    <div class="mb-4" id="quickActionsSection">
      <h6 class="text-secondary text-uppercase tracking-wider small fw-semibold mb-3">บันทึกด่วน (Quick Actions)</h6>
      <div class="row g-3">
        <% 
          const maxQuickActionsLimit = locals.systemSettings?.max_quick_actions || 6;
          let quickActionIds = typeof user !== 'undefined' && user.quick_actions ? user.quick_actions.split(',').map(s => s.trim()).filter(Boolean) : [];
          let quickActivities = [];
          if (typeof activities !== 'undefined' && activities.length > 0 && quickActionIds.length > 0) {
            quickActivities = quickActionIds.map(id => activities.find(a => a.id.toString() === id)).filter(Boolean);
          }
          quickActivities = quickActivities.slice(0, maxQuickActionsLimit);
          if (quickActivities.length > 0) {
            quickActivities.forEach(function(act, index) {
        %>
        <div class="col-md-6 col-lg-4">
          <div class="card card-hospital p-3 cursor-pointer d-flex flex-row align-items-center justify-content-between border" onclick="selectActivityQuick(<%= act.id %>, '<%= act.code %>: <%= act.name.replace(/'/g, "\\'") %>')">
            <div class="d-flex align-items-center gap-3 w-100">
              <div class="bg-hospital-light text-teal rounded p-2 d-flex align-items-center justify-content-center fw-bold" style="width: 32px; height: 32px;"><%= index + 1 %></div>
              <div class="text-truncate flex-grow-1">
                <h6 class="fw-bold text-dark mb-0 text-truncate" title="<%= act.name %>"><%= act.name %></h6>
              </div>
            </div>
          </div>
        </div>
        <% 
            });
          } else { 
        %>
        <div class="col-12">
          <div class="p-3 text-muted small text-center border rounded border-dashed">ยังไม่มีบันทึกด่วน กดไอคอนรูปเข็มหมุดที่รายการด้านล่างเพื่อเพิ่ม</div>
        </div>
        <% } %>
      </div>
    </div>

    <!-- Browse Category Section (Todoist style navigation) -->
    <div class="mb-4">
      <h6 class="text-secondary text-uppercase tracking-wider small fw-semibold mb-3">เลือกหมวดหมู่กิจกรรม (Browse Category)</h6>
      <div class="d-flex flex-wrap gap-2">
        <button type="button" class="chip-btn active filter-category-btn" onclick="filterByCategory('all', this)">ทั้งหมด</button>
        <% 
          let prefs = typeof user !== 'undefined' && user.preferred_categories 
                        ? user.preferred_categories.split(',').map(s => s.trim()) 
                        : [];
          if (typeof categories !== 'undefined' && categories && categories.length > 0) {
            categories.forEach(function(cat) { 
              if (prefs.length === 0 || prefs.includes(cat.id.toString())) {
        %>
            <button type="button" class="chip-btn filter-category-btn" onclick="filterByCategory('<%= cat.name %>', this)"><%= cat.name %></button>
        <% 
              }
            }); 
          } 
        %>
      </div>
    </div>

    <!-- Active List of Activities -->
    <div class="card card-hospital border-0 p-3">
      <div class="d-flex flex-column gap-2" id="activitiesListContainer">
        <!-- Rendered dynamically -->
      </div>
    </div>

  </div>
</div>

<!-- Modal Quick Entry Form (Google Keep style popup) -->
<div class="modal fade" id="recordFormModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 480px;">
    <div class="modal-content border-0 rounded-card shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="fw-bold text-dark" id="modalActivityTitle">บันทึกกิจกรรม</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      
      <form action="/activity/create" method="POST" class="needs-validation" novalidate id="createActivityForm">
        <div class="modal-body py-3">
          <input type="hidden" id="modalActivityId" name="activityMasterId" required>
          
          <div class="mb-3">
            <label class="form-label text-secondary small fw-semibold">กิจกรรมหลัก</label>
            <input type="text" class="form-control rounded-3 bg-light border-0 fw-semibold" id="modalActivityNameDisplay" readonly>
          </div>

          <!-- Date Selection (วันนี้ / ย้อนหลัง 1 วัน / เลือกเอง) -->
          <div class="mb-3">
            <label class="form-label text-secondary small fw-semibold">วันที่ปฏิบัติงาน</label>
            <div class="segmented-control mb-2" id="createDateGroup">
              <button type="button" class="chip-btn active" onclick="setCreateDateMode('today', this)">วันนี้</button>
              <button type="button" class="chip-btn" onclick="setCreateDateMode('yesterday', this)">ย้อนหลัง 1 วัน</button>
              <button type="button" class="chip-btn" onclick="setCreateDateMode('custom', this)">เลือกวันที่เอง</button>
            </div>
            <div id="createLogDateContainer" class="d-none mt-2">
              <input type="date" name="logDate" id="createLogDate" class="form-control rounded-3">
            </div>
          </div>

          <!-- Session selection (เช้า / บ่าย / ทั้งวัน) -->
          <div class="mb-3">
            <label class="form-label text-secondary small fw-semibold">ช่วงเวลาปฏิบัติงาน</label>
            <div class="segmented-control" id="formSessionGroup">
              <button type="button" class="chip-btn active" onclick="setFormSession('Morning', this)">เช้า</button>
              <button type="button" class="chip-btn" onclick="setFormSession('Afternoon', this)">บ่าย</button>
              <button type="button" class="chip-btn" onclick="setFormSession('Night', this)">ค่ำ/OT</button>
              <button type="button" class="chip-btn" onclick="setFormSession('AllDay', this)">ทั้งวัน</button>
            </div>
            <input type="hidden" name="session" id="formSelectedSession" value="Morning">
          </div>

          <!-- Duration spent quick chips (15, 30, 60, 120 นาที) -->
          <div class="mb-3">
            <label class="form-label text-secondary small fw-semibold">ระยะเวลาที่ใช้งาน (นาที)</label>
            <div class="segmented-control mb-2" id="formDurationGroup">
              <button type="button" class="chip-btn" onclick="setFormDuration(15, this)">15 นาที</button>
              <button type="button" class="chip-btn active" onclick="setFormDuration(30, this)">30 นาที</button>
              <button type="button" class="chip-btn" onclick="setFormDuration(60, this)">60 นาที</button>
              <button type="button" class="chip-btn" onclick="setFormDuration(120, this)">120 นาที</button>
            </div>
            <div class="input-group input-group-sm mt-2">
              <span class="input-group-text bg-light text-secondary border-0">ระยะเวลาอื่น</span>
              <input type="number" name="duration" id="formSelectedDuration" class="form-control" value="30" min="1" required placeholder="ระบุนาที">
            </div>
          </div>

          <!-- Location dropdown selector -->
          <div class="mb-3">
            <label for="formLocation" class="form-label text-secondary small fw-semibold">สถานที่ปฏิบัติงาน</label>
            <select class="form-select rounded-3" id="formLocation" name="locationId">
              <option value="">เลือกสถานที่...</option>
              <% if (typeof locations !== 'undefined' && locations && locations.length > 0) { %>
                <% locations.forEach(function(loc) { %>
                  <% const isDefault = loc.name.includes('กลุ่มงานดิจิทัล') || loc.name.includes('ดิจิทัล'); %>
                  <option value="<%= loc.id %>" <%= isDefault ? 'selected' : '' %>><%= loc.name %></option>
                <% }); %>
              <% } %>
            </select>
          </div>

          <!-- Outcome / Deliverables results -->
          <div class="mb-3">
            <label for="formOutput" class="form-label text-secondary small fw-semibold">ผลงาน / สิ่งที่ส่งมอบ</label>
            <textarea class="form-control rounded-3" id="formOutput" name="output" rows="2" placeholder="อธิบายผลงานการปฏิบัติงาน..."></textarea>
          </div>

          <!-- Remarks -->
          <div class="mb-3">
            <label for="formRemark" class="form-label text-secondary small fw-semibold">หมายเหตุ</label>
            <textarea class="form-control rounded-3" id="formRemark" name="remark" rows="1" placeholder="ความเห็นเพิ่มเติม..."></textarea>
          </div>
        </div>

        <div class="modal-footer border-0 pt-0">
          <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">ยกเลิก</button>
          <button type="submit" class="btn btn-hospital rounded-3 px-4">บันทึกภาระงาน</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  // All system activities defined for search filtering from DB
  const allActivities = <%- typeof activities !== 'undefined' && activities ? JSON.stringify(activities.map(act => ({
    id: act.id.toString(),
    name: `${act.code}: ${act.name}`,
    category: act.categoryName,
    categoryId: act.category_id ? act.category_id.toString() : ''
  }))) : '[]' %>;

  const userPrefs = <%- typeof user !== 'undefined' && user.preferred_categories ? JSON.stringify(user.preferred_categories.split(',').map(s=>s.trim())) : '[]' %>;
  let currentQuickActions = <%- typeof user !== 'undefined' && user.quick_actions ? JSON.stringify(user.quick_actions.split(',').map(s=>s.trim()).filter(Boolean)) : '[]' %>;
  const maxQuickActionsLimit = <%= locals.systemSettings?.max_quick_actions || 6 %>;

  function getFilteredAllActivities() {
    if (userPrefs.length === 0 || (userPrefs.length === 1 && userPrefs[0] === "")) return allActivities;
    return allActivities.filter(act => userPrefs.includes(act.categoryId));
  }

  let recordModal;

  document.addEventListener('DOMContentLoaded', () => {
    if (typeof bootstrap !== 'undefined') {
      recordModal = new bootstrap.Modal(document.getElementById('recordFormModal'));
    }
    
    // Render initial activity list
    renderActivityList(getFilteredAllActivities());

    // Search and autocomplete logic
    const searchInput = document.getElementById('activitySearchInput');
    const autocompleteList = document.getElementById('searchAutocompleteList');

    searchInput.addEventListener('input', () => {
      const value = searchInput.value.toLowerCase().trim();
      if (!value) {
        autocompleteList.classList.add('d-none');
        renderActivityList(getFilteredAllActivities());
        return;
      }

      // Filter matches
      const matches = allActivities.filter(act => act.name.toLowerCase().includes(value));
      
      // Render Autocomplete Dropdown
      if (matches.length > 0) {
        autocompleteList.innerHTML = matches.map(match => `
          <div class="search-autocomplete-item" onclick="selectActivityQuick(${match.id}, '${match.name.replace(/'/g, "\\'")}')">
            <span class="fw-semibold text-dark">${match.name}</span>
          </div>
        `).join('');
        autocompleteList.classList.remove('d-none');
      } else {
        autocompleteList.innerHTML = `<div class="p-3 text-muted small text-center">ไม่พบกิจกรรมหลัก กรุณาลองคำค้นอื่น</div>`;
        autocompleteList.classList.remove('d-none');
      }

      // Update the main container below too
      renderActivityList(matches);
    });

    // Close autocomplete on click outside
    document.addEventListener('click', (e) => {
      if (!searchInput.contains(e.target) && !autocompleteList.contains(e.target)) {
        autocompleteList.classList.add('d-none');
      }
    });

    // Warning popup for exceeding 7 hours
    const form = document.getElementById('createActivityForm');
    if (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault();
          event.stopPropagation();
          form.classList.add('was-validated');
          return;
        }

        // Prevent default submit first to show Swal
        event.preventDefault();

        const todayTotal = <%= typeof todayTotalMinutes !== 'undefined' ? todayTotalMinutes : 0 %>;
        const durationInput = document.getElementById('formSelectedDuration');
        const durationVal = parseInt(durationInput?.value || 0, 10);
        const projectedTotal = todayTotal + durationVal;

        if (projectedTotal > 420) {
          Swal.fire({
            title: 'เวลาทำงานสะสมเกิน 7 ชั่วโมง',
            html: `วันนี้คุณบันทึกเวลาทำงานสะสมไปแล้ว <strong>${todayTotal} นาที</strong><br>` +
                  `และรายการนี้ระบุ <strong>${durationVal} นาที</strong><br>` +
                  `ทำให้เวลารวมสะสมเป็น <strong>${projectedTotal} นาที</strong> (~${(projectedTotal/60).toFixed(1)} ชม.)<br><br>` +
                  `คุณแน่ใจหรือไม่ว่าใส่ระยะเวลาถูกต้องแล้ว?`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#0D9488',
            cancelButtonColor: '#94A3B8',
            confirmButtonText: 'ใช่ บันทึกเลย',
            cancelButtonText: 'ยกเลิกเพื่อแก้ไข'
          }).then((result) => {
            if (result.isConfirmed) {
              form.classList.add('was-validated');
              form.submit();
            }
          });
        } else {
          form.classList.add('was-validated');
          form.submit();
        }
      });
    }
  });

  function renderActivityList(items) {
    const container = document.getElementById('activitiesListContainer');
    if (items.length === 0) {
      container.innerHTML = `<div class="text-center py-4 text-secondary small">ไม่พบรายการกิจกรรม</div>`;
      return;
    }

    container.innerHTML = items.map(act => `
      <div class="d-flex align-items-center justify-content-between p-2.5 rounded-card hover-bg-light-subtle cursor-pointer border" onclick="selectActivityQuick(${act.id}, '${act.name.replace(/'/g, "\\'")}')">
        <div class="d-flex align-items-center gap-3">
          <div class="bg-hospital-light text-teal rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
            <i class="bi bi-clipboard2-check"></i>
          </div>
          <div>
            <span class="fw-semibold text-dark text-sm d-block">${act.name}</span>
            <span class="badge bg-light text-secondary border text-xs">${act.category}</span>
          </div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <button type="button" class="btn btn-sm ${currentQuickActions.includes(act.id) ? 'btn-warning text-white' : 'btn-light border'} rounded-circle pin-btn" onclick="toggleQuickAction('${act.id}', event)" title="ปักหมุดบันทึกด่วน">
            <i class="bi bi-pin-angle${currentQuickActions.includes(act.id) ? '-fill' : ''}"></i>
          </button>
          <button type="button" class="btn btn-sm btn-light border rounded-circle"><i class="bi bi-plus-lg"></i></button>
        </div>
      </div>
    `).join('');
  }

  function filterByCategory(category, element) {
    // Update active chip state
    document.querySelectorAll('.filter-category-btn').forEach(btn => btn.classList.remove('active'));
    element.classList.add('active');

    // Filter and render
    if (category === 'all') {
      renderActivityList(getFilteredAllActivities());
    } else {
      const filtered = getFilteredAllActivities().filter(act => act.category === category);
      renderActivityList(filtered);
    }
  }

  function clearSearch() {
    const searchInput = document.getElementById('activitySearchInput');
    searchInput.value = '';
    document.getElementById('searchAutocompleteList').classList.add('d-none');
    renderActivityList(getFilteredAllActivities());
  }

  function selectActivityQuick(id, name) {
    document.getElementById('modalActivityId').value = id;
    document.getElementById('modalActivityNameDisplay').value = name;
    
    // Reset values to defaults
    setFormSession('Morning', document.querySelector('#formSessionGroup .chip-btn:first-child'));
    setFormDuration(30, document.querySelector('#formDurationGroup .chip-btn:nth-child(2)'));
    setCreateDateMode('today', document.querySelector('#createDateGroup .chip-btn:first-child'));
    
    // Hide autocomplete drop
    document.getElementById('searchAutocompleteList').classList.add('d-none');
    
    recordModal.show();
  }

  function setCreateDateMode(mode, element) {
    const btns = document.querySelectorAll('#createDateGroup .chip-btn');
    btns.forEach(btn => btn.classList.remove('active'));
    element.classList.add('active');

    const dateContainer = document.getElementById('createLogDateContainer');
    const dateInput = document.getElementById('createLogDate');
    
    const today = new Date();
    const getLocalDateString = () => {
      const year = today.getFullYear();
      const month = String(today.getMonth() + 1).padStart(2, '0');
      const day = String(today.getDate()).padStart(2, '0');
      return `${year}-${month}-${day}`;
    };

    if (mode === 'today') {
      dateContainer.classList.add('d-none');
      dateInput.value = getLocalDateString();
    } else if (mode === 'yesterday') {
      dateContainer.classList.add('d-none');
      const yesterday = new Date(today);
      yesterday.setDate(yesterday.getDate() - 1);
      const yYear = yesterday.getFullYear();
      const yMonth = String(yesterday.getMonth() + 1).padStart(2, '0');
      const yDay = String(yesterday.getDate()).padStart(2, '0');
      dateInput.value = `${yYear}-${yMonth}-${yDay}`;
    } else if (mode === 'custom') {
      dateContainer.classList.remove('d-none');
      if (!dateInput.value) {
        dateInput.value = getLocalDateString();
      }
    }
  }

  function setFormSession(value, element) {
    document.getElementById('formSelectedSession').value = value;
    const btns = document.querySelectorAll('#formSessionGroup .chip-btn');
    btns.forEach(btn => btn.classList.remove('active'));
    element.classList.add('active');
    
    const durationInput = document.getElementById('formSelectedDuration');
    const durationGroup = document.getElementById('formDurationGroup');
    
    if (value === 'AllDay') {
      if (durationInput) {
        durationInput.value = '420';
        durationInput.readOnly = true;
        durationInput.classList.add('bg-light');
      }
      if (durationGroup) {
        durationGroup.querySelectorAll('.chip-btn').forEach(btn => {
          btn.classList.remove('active');
          btn.disabled = true;
        });
      }
    } else {
      if (durationInput) {
        durationInput.readOnly = false;
        durationInput.classList.remove('bg-light');
        if (durationInput.value === '420') {
          durationInput.value = '30';
          // Set active chip for 30 mins
          const chip30 = durationGroup?.querySelector('.chip-btn:nth-child(2)');
          if (chip30) chip30.classList.add('active');
        }
      }
      if (durationGroup) {
        durationGroup.querySelectorAll('.chip-btn').forEach(btn => {
          btn.disabled = false;
        });
      }
    }
  }

  function setFormDuration(value, element) {
    document.getElementById('formSelectedDuration').value = value;
    const btns = document.querySelectorAll('#formDurationGroup .chip-btn');
    btns.forEach(btn => btn.classList.remove('active'));
    element.classList.add('active');
  }

  async function toggleQuickAction(id, event) {
    event.stopPropagation(); // Prevent opening modal
    const strId = id.toString();
    const index = currentQuickActions.indexOf(strId);
    
    if (index > -1) {
      currentQuickActions.splice(index, 1);
    } else {
      if (currentQuickActions.length >= maxQuickActionsLimit) {
        Swal.fire('เกินจำนวนที่กำหนด', `สามารถปักหมุดบันทึกด่วนได้สูงสุด ${maxQuickActionsLimit} รายการ กรุณาปลดรายการเก่าออกก่อน`, 'warning');
        return;
      }
      currentQuickActions.push(strId);
    }
    
    // Save to server
    try {
      const response = await fetch('/users/quick-actions', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ quick_actions: currentQuickActions.join(',') })
      });
      const data = await response.json();
      if (data.success) {
        // Reload to render new EJS blocks
        window.location.reload();
      } else {
        Swal.fire('ผิดพลาด', 'ไม่สามารถบันทึกได้', 'error');
      }
    } catch(err) {
       console.error(err);
       Swal.fire('ผิดพลาด', 'เกิดข้อผิดพลาดในการเชื่อมต่อเซิร์ฟเวอร์', 'error');
    }
  }
</script>
