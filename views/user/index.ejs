      </tbody>
    </table>
  </div>
</div>

<!-- Modal Add User -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 460px;">
    <div class="modal-content border-0 rounded-card shadow-lg">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold text-dark">เพิ่มผู้ใช้งาน</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body py-3">
        <div class="mb-3">
          <label for="newFullName" class="form-label text-secondary small fw-semibold">ชื่อ-นามสกุล</label>
          <input type="text" class="form-control rounded-3" id="newFullName" placeholder="เช่น นายวันชัย มั่นคง" required>
        </div>
        <div class="mb-3">
          <label for="newEmail" class="form-label text-secondary small fw-semibold">อีเมล</label>
          <input type="email" class="form-control rounded-3" id="newEmail" placeholder="เช่น username@hospital.go.th" required>
        </div>
        <div class="mb-3">
          <label for="newPosition" class="form-label text-secondary small fw-semibold">ตำแหน่งงาน</label>
          <input type="text" class="form-control rounded-3" id="newPosition" placeholder="เช่น นักวิชาการคอมพิวเตอร์" required>
        </div>
        <div class="mb-3">
          <label for="newRole" class="form-label text-secondary small fw-semibold">ระดับสิทธิ์ (Permissions)</label>
          <select class="form-select rounded-3" id="newRole" required>
            <option value="Staff">เจ้าหน้าที่ทั่วไป (Staff)</option>
            <option value="Admin">ผู้ดูแลระบบ (Admin)</option>
            <option value="Head">หัวหน้ากลุ่มงาน (Head)</option>
          </select>
        </div>
      </div>
      <div class="modal-footer border-0 pt-0">
        <button type="button" class="btn btn-light rounded-3 px-4" data-bs-dismiss="modal">ยกเลิก</button>
        <button type="button" class="btn btn-hospital rounded-3 px-4" data-bs-dismiss="modal">สร้างผู้ใช้</button>
      </div>
    </div>
  </div>
</div>
