              <div>
                <span class="fw-semibold text-dark d-block">เกียรติศักดิ์ รักดี</span>
                <span class="text-secondary text-xs">kiatisak.r@hospital.go.th</span>
              </div>
            </div>
          </td>
          <td>kiatisak.r</td>
          <td class="text-secondary">นักวิชาการคอมพิวเตอร์</td>
          <td><span class="badge bg-success-subtle text-teal border border-success-subtle rounded-2">ผู้ดูแลระบบ</span></td>
          <td><span class="badge bg-success-subtle text-success border border-success-subtle rounded-2">ใช้งาน</span></td>
          <td class="pe-3 text-end">
            <button class="btn btn-sm btn-light border rounded-2 p-1.5"><i class="bi bi-pencil"></i></button>
          </td>
        </tr>
        <!-- pimonwan -->
        <tr>
          <td class="ps-3">
            <div class="d-flex align-items-center gap-3">
              <div class="bg-hospital-light text-teal fw-bold d-flex align-items-center justify-content-center rounded-circle" style="width: 36px; height: 36px;">
